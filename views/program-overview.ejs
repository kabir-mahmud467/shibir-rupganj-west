<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>কর্মসূচি ওভারভিউ | বাংলাদেশ ইসলামী ছাত্রশিবির - রূপগঞ্জ পশ্চিম</title>
    <link rel="icon" type="image/png" href="https://www.dushibir.org/storage/setting_images/wKFhZtq3w8jQDZT9wLfeJJXeGW09yJss7WACq03k.png">
    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        :root {
            --bg-dark: #050a0e;
            --accent-green: #00b366;
            --accent-yellow: #f59e0b;
        }

        body {
            font-family: 'Hind Siliguri', sans-serif;
            background-color: var(--bg-dark);
            color: #ffffff;
            background-image: 
                radial-gradient(at 0% 0%, rgba(0, 129, 68, 0.15) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(59, 130, 246, 0.15) 0px, transparent 50%);
            background-attachment: fixed;
            min-height: 100vh;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            transition: all 0.3s ease;
        }

        .program-card {
            padding: 40px;
            text-align: center;
            height: 100%;
            border-bottom: 4px solid transparent;
        }

        .program-card:hover {
            transform: translateY(-10px);
            background: rgba(255, 255, 255, 0.06);
            border-bottom-color: var(--accent-green);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }

        .icon-circle {
            width: 80px;
            height: 80px;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 2rem;
            transition: 0.3s;
        }

        .program-card:hover .icon-circle {
            background: var(--accent-green);
            color: white;
            transform: scale(1.1);
        }

        .section-tag {
            display: inline-block;
            padding: 8px 20px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 50px;
            color: var(--accent-yellow);
            font-weight: 700;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <%- include('partials/main-nav') %>

    <div class="container py-5">
        <div class="text-center mb-5 mt-5">
            <span class="section-tag">Working Plan Detail</span>
            <h1 class="display-4 fw-bold">৫ দফা কর্মসূচি</h1>
            <p class="text-light opacity-75 max-width-700 mx-auto">
                বাংলাদেশ ইসলামী ছাত্রশিবিরের মূল লক্ষ্য ও কর্মপন্থা। আমাদের প্রতিটি কাজের ভিত্তি এই ৫টি বিষয়।
            </p>
        </div>

        <div class="row g-4 justify-content-center">
            <% Object.keys(programs).forEach(key => { %>
                <% const p = programs[key]; %>
                <div class="col-lg-4 col-md-6">
                    <a href="/program/<%= key %>" class="text-decoration-none">
                        <div class="glass-card program-card">
                            <div class="icon-circle dynamic-p-icon" data-color="<%= p.color %>">
                                <i class="fas <%= p.icon %>"></i>
                            </div>
                            <h3 class="text-white fw-bold mb-3"><%= p.title %></h3>
                            <p class="text-light opacity-75 mb-4 small">
                                <%= p.description.substring(0, 100) %>...
                            </p>
                            <span class="btn btn-sm btn-outline-success rounded-pill px-4">বিস্তারিত দেখুন</span>
                        </div>
                    </a>
                </div>
            <% }) %>
        </div>
        <script>
            document.querySelectorAll('.dynamic-p-icon').forEach(el => {
                const color = el.dataset.color;
                el.style.color = color;
                el.style.border = `1px solid ${color}33`;
            });
        </script>

        <div class="text-center mt-5">
            <a href="/" class="btn btn-outline-light rounded-pill px-5">হোমে ফিরে যান</a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
