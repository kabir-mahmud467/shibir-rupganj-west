<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <title>প্রোফাইল</title>
    <style>
        body { background: #020617; color: white; font-family: sans-serif; }
        .card { max-width: 600px; margin: 50px auto; background: rgba(30, 41, 59, 0.5); padding: 30px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1); }
        .info { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 20px; }
        .box { background: #0f172a; padding: 10px; border-radius: 8px; }
        label { font-size: 0.8rem; color: #94a3b8; }
        .val { font-weight: bold; color: #00d2ff; }
    </style>
</head>
<body>
    <%- include('partials/nav', {user: user}) %>
    <div class="card">
        <center>
            <img src="/uploads/<%= profile.photo %>" style="width:120px; height:120px; border-radius:50%; border:3px solid #00d2ff; object-fit:cover;">
            <h2><%= profile.name %></h2>
            <span style="background:#10b981; padding:5px 15px; border-radius:20px;"><%= profile.type %></span>
        </center>
        
        <div class="info">
            <div class="box"><label>পিতার নাম</label><div class="val"><%= profile.father || '-' %></div></div>
            <div class="box"><label>মাতার নাম</label><div class="val"><%= profile.mother || '-' %></div></div>
            <div class="box"><label>জন্ম তারিখ</label><div class="val"><%= profile.dob || '-' %></div></div>
            <div class="box"><label>শিক্ষা</label><div class="val"><%= profile.edu === 'অন্যান্য' ? profile.edu_other : profile.edu %></div></div>
            <div class="box"><label>প্রতিষ্ঠান</label><div class="val"><%= profile.inst === 'অন্যান্য' ? profile.inst_other : profile.inst %></div></div>
            <div class="box"><label>দায়িত্ব</label><div class="val"><%= profile.responsibility %></div></div>
            <div class="box"><label>অগ্রগতি</label><div class="val"><%= profile.progress %></div></div>
        </div>
        <div class="box" style="margin-top:15px;"><label>মন্তব্য</label><div class="val"><%= profile.comment %></div></div>
        <p style="text-align:center; color:#ef4444; font-size:0.8rem; margin-top:20px;">* তথ্য পরিবর্তনের জন্য অ্যাডমিনের সাথে যোগাযোগ করুন।</p>
    </div>
</body>
</html>