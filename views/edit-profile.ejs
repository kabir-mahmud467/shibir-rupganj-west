<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('partials/seo') %>

    <title>প্রোফাইল এডিট করুন | রূপগঞ্জ পশ্চিম</title>
     <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        :root { --primary-green: #00b74a; --glass-white: rgba(255, 255, 255, 0.08); --glass-border: rgba(255, 255, 255, 0.1); }
        body { font-family: 'Hind Siliguri', sans-serif; background: #050a0e; color: white; min-height: 100vh; }
        .form-container { max-width: 700px; margin: 30px auto; padding-bottom: 50px; }
        .edit-profile-card { background: var(--glass-white); backdrop-filter: blur(15px); border: 1px solid var(--glass-border); border-radius: 20px; padding: 40px; }
        .form-label { color: #80c956; font-weight: 600; font-size: 0.95rem; margin-bottom: 8px; display: block; }
        .form-control { background: rgba(0, 129, 68, 0.1); border: 1px solid var(--glass-border); color: white; border-radius: 10px; padding: 12px 15px; margin-bottom: 20px; width: 100%; box-sizing: border-box; }
        .form-control:focus { background: rgba(0, 129, 68, 0.2); border-color: var(--primary-green); outline: none; box-shadow: 0 0 15px rgba(0, 129, 68, 0.3); color: white; }
        .section-title { color: #80c956; font-size: 1.1rem; font-weight: 600; margin: 30px 0 15px; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid rgba(128, 201, 86, 0.2); padding-bottom: 5px; }
        .btn-submit { background: linear-gradient(135deg, var(--primary-green), #00a859); border: none; color: white; font-weight: 700; padding: 14px; border-radius: 10px; width: 100%; margin-top: 25px; transition: 0.3s; cursor: pointer; }
        .btn-submit:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0, 129, 68, 0.4); }
        .back-link { color: #80c956; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; margin-bottom: 20px; }
    </style>
</head>
<body>
    <%- include('partials/main-nav') %>

    <div class="form-container">
        <div class="edit-profile-card">
            <a href="/profile" class="back-link"><i class="fas fa-arrow-left"></i> ফিরে যান</a>
            
            <h2 class="text-white fw-bold mb-4"><i class="fas fa-user-edit me-2" style="color: #80c956;"></i> তথ্য পরিবর্তন করুন</h2>

            <form action="/update-profile" method="POST" enctype="multipart/form-data">
                <div class="section-title"><i class="fas fa-camera me-2"></i> ছবি পরিবর্তন</div>
                <% if(user.photo) { %>
                    <div style="margin-bottom: 15px; display: flex; align-items: center; gap: 15px;">
                        <img src="<%= user.photo %>" width="60" height="60" style="border-radius: 50%; object-fit: cover; border: 2px solid #00b74a;">
                        <span style="font-size: 12px; color: #94a3b8;">বর্তমান ছবি সেট করা আছে।</span>
                    </div>
                <% } %>
                <input type="file" name="photo" class="form-control" accept="image/*">

                <div class="section-title"><i class="fas fa-person me-2"></i> সাধারণ তথ্য</div>
                
                <label class="form-label">নাম *</label>
                <input type="text" name="name" class="form-control" value="<%= user.name %>" required>

                <label class="form-label">ফোন নম্বর</label>
                <input type="tel" name="phone" class="form-control" value="<%= user.phone || '' %>">

                <label class="form-label">ফেসবুক আইডি লিঙ্ক</label>
                <input type="text" name="facebook" class="form-control" value="<%= user.facebook || '' %>">

                <% if (session.type === 'member') { %>
                    <div class="section-title"><i class="fas fa-file-invoice me-2"></i> ব্যক্তিগত বিস্তারিত</div>
                    <label class="form-label">বাবার নাম</label>
                    <input type="text" name="father" class="form-control" value="<%= user.father || '' %>">

                    <label class="form-label">মায়ের নাম</label>
                    <input type="text" name="mother" class="form-control" value="<%= user.mother || '' %>">

                    <label class="form-label">জন্মতারিখ</label>
                    <input type="date" name="dob" class="form-control" value="<%= user.dob || '' %>">

                    <label class="form-label">অভিভাবক ফোন নম্বর</label>
                    <input type="tel" name="guardian_phone" class="form-control" value="<%= user.guardian_phone || '' %>">

                    <div class="section-title"><i class="fas fa-school me-2"></i> শিক্ষা তথ্য</div>
                    <label class="form-label">শিক্ষা প্রতিষ্ঠানের নাম</label>
                    <input type="text" name="inst" class="form-control" value="<%= user.inst || '' %>">

                    <label class="form-label">শিক্ষা স্তর</label>
                    <input type="text" name="edu" class="form-control" value="<%= user.edu || '' %>">
                <% } %>

                <div class="section-title"><i class="fas fa-map-marker-alt me-2"></i> ঠিকানা</div>
                <label class="form-label">ঠিকানা</label>
                <textarea name="present_address" class="form-control" rows="3"><%= user.present_address || user.address || '' %></textarea>

                <% if (session.type === 'member') { %>
                    <label class="form-label">স্থায়ী ঠিকানা</label>
                    <textarea name="permanent_address" class="form-control" rows="3"><%= user.permanent_address || '' %></textarea>
                <% } %>

                <button type="submit" class="btn-submit">
                    <i class="fas fa-save me-2"></i> তথ্য সংরক্ষণ করুন
                </button>

                <div style="text-align: center; margin-top: 15px;">
                    <a href="/profile" style="color: #999; text-decoration: none;">বাতিল করুন</a>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
