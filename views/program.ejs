<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('partials/seo') %>

    <title><%= program.title %> | বাংলাদেশ ইসলামী ছাত্রশিবির - রূপগঞ্জ পশ্চিম</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        :root {
            --program-color: <%= program.color %>;
            --program-color-alpha: <%= program.color %>33;
        }

        .program-header {
            padding: 80px 0 40px;
            text-align: center;
            background: linear-gradient(to bottom, rgba(0, 129, 68, 0.1), transparent);
        }
        .program-icon-box {
            width: 100px;
            height: 100px;
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid var(--program-color);
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 25px;
            font-size: 3rem;
            color: var(--program-color);
            box-shadow: 0 10px 30px var(--program-color-alpha);
        }
        .detail-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            padding: 40px;
            margin-top: -30px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        }
        .point-item {
            display: flex;
            gap: 15px;
            margin-bottom: 20px;
            background: rgba(255, 255, 255, 0.03);
            padding: 15px 20px;
            border-radius: 15px;
            border-left: 4px solid var(--program-color);
            transition: 0.3s;
        }
        .point-item:hover {
            background: rgba(255, 255, 255, 0.06);
            transform: translateX(10px);
        }
        .point-number {
            width: 25px;
            height: 25px;
            background: var(--program-color);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 0.8rem;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <%- include('partials/main-nav') %>

    <div class="program-header">
        <div class="container">
            <div class="program-icon-box">
                <i class="fas <%= program.icon %>"></i>
            </div>
            <h1 class="display-4 fw-bold text-white mb-3"><%= program.title %></h1>
            <p class="lead text-light opacity-75 max-width-700 mx-auto">
                আমাদের ৫ দফার গুরুত্বপূর্ণ এই কর্মসূচির বিস্তারিত বিবরণ।
            </p>
        </div>
    </div>

    <div class="container mb-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="detail-card">
                    <h3 class="fw-bold text-white mb-4">
                        <i class="fas fa-info-circle me-2" style="color: var(--program-color)"></i>বিবরণ
                    </h3>
                    <p class="fs-5 text-light opacity-90 lh-lg mb-5">
                        <%= program.description %>
                    </p>

                    <h4 class="fw-bold text-white mb-4">
                        <i class="fas fa-list-check me-2" style="color: var(--program-color)"></i>কার্যক্রমসমূহ
                    </h4>
                    <div class="points-list">
                        <% program.details.forEach((detail, index) => { %>
                            <div class="point-item">
                                <span class="point-number"><%= index + 1 %></span>
                                <div class="text-light opacity-90"><%= detail %></div>
                            </div>
                        <% }) %>
                    </div>

                    <div class="text-center mt-5">
                        <a href="/" class="btn btn-outline-light rounded-pill px-5 py-2">
                            <i class="fas fa-arrow-left me-2"></i>হোমে ফিরে যান
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
