<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('partials/seo') %>

    <title>জনশক্তি তথ্য পরিবর্তন | রূপগঞ্জ পশ্চিম</title>
    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* edit-member.ejs specific styles only */
        .edit-member-card { 
            background: rgba(30, 41, 59, 0.4); 
            backdrop-filter: blur(15px);
            padding: 30px; 
            border-radius: 20px; 
            max-width: 700px; 
            margin: 20px auto; 
            border: 1px solid rgba(255,255,255,0.1); 
            box-shadow: 0 10px 30px rgba(0,0,0,0.5); 
        }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        label { display: block; margin-top: 15px; color: #94a3b8; font-size: 14px; font-weight: 500; }
        input, select, textarea { 
            width: 100%; padding: 12px; margin: 5px 0; border-radius: 10px; 
            background: #0f172a; color: white; border: 1px solid #334155; 
            box-sizing: border-box; outline: none; transition: 0.3s;
        }
        input:focus, select:focus, textarea:focus { border-color: #3b82f6; box-shadow: 0 0 10px rgba(59, 130, 246, 0.2); }
        
        .btn { 
            background: linear-gradient(45deg, #00d2ff, #3a7bd5); 
            color: white; border: none; padding: 15px; border-radius: 10px; 
            cursor: pointer; width: 100%; font-weight: bold; margin-top: 25px; 
            font-size: 16px; transition: 0.3s;
        }
        .btn:hover { transform: translateY(-2px); opacity: 0.9; }
        
        .other-box { border-left: 3px solid #3b82f6; padding-left: 15px; margin-top: 10px; }
        
        .current-photo {
            display: flex; align-items: center; gap: 15px;
            background: rgba(255,255,255,0.05); padding: 10px; border-radius: 10px; margin-top: 5px;
        }

        /* Monthly Payment Grid Styles */
        .month-label {
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            background: rgba(239,68,68,0.1);
            border: 2px solid rgba(239,68,68,0.4);
            border-radius: 10px; padding: 12px 8px; cursor: pointer;
            transition: all 0.2s; gap: 6px;
        }
        .month-label.paid {
            background: rgba(16,185,129,0.15);
            border-color: #10b981;
        }
        .month-label.paid span:first-child { color: #10b981; }
        .month-label.paid span:last-of-type { color: #10b981 !important; }
        .month-label span:first-child { font-size: 20px; font-weight: bold; }
        .month-label span:last-of-type { font-size: 11px; color: #ef4444; font-weight: 600; }

        @media (max-width: 600px) {
            .grid { grid-template-columns: 1fr; gap: 0; }
            .card { padding: 20px; }
        }
    </style>
</head>
<body>
    <%- include('partials/main-nav') %>
    <div class="edit-member-card" style="margin-top: 40px; margin-bottom: 40px;">
        <h2 style="text-align:center; color:#00d2ff; margin-bottom:25px;">
            <i class="fas fa-user-edit"></i> জনশক্তির তথ্য আপডেট
        </h2>
        
        <form action="/admin/update-member/<%= member.id %>" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            
            <div class="grid">
                <div>
                    <label><i class="fas fa-user me-1"></i> নাম (অবশ্যই):</label>
                    <input type="text" name="name" value="<%= member.name %>" required>
                </div>
                <div>
                    <label><i class="fas fa-layer-group me-1"></i> সাংগঠনিক মান:</label>
                    <select name="type">
                        <option value="কর্মী" <%= member.type === 'কর্মী' ? 'selected' : '' %>>কর্মী</option>
                        <option value="সাথী" <%= member.type === 'সাথী' ? 'selected' : '' %>>সাথী</option>
                    </select>
                </div>
            </div>

            <div class="grid">
                <div>
                    <label>পিতার নাম:</label>
                    <input type="text" name="father" value="<%= member.father %>">
                </div>
                <div>
                    <label>মাতার নাম:</label>
                    <input type="text" name="mother" value="<%= member.mother %>">
                </div>
            </div>

            <div class="grid">
                <div>
                    <label>জন্ম তারিখ:</label>
                    <input type="date" name="dob" value="<%= member.dob %>">
                </div>
                <div>
                    <label><i class="fas fa-phone me-1"></i> ফোন নম্বর:</label>
                    <input type="text" name="phone" value="<%= member.phone %>" required>
                </div>
            </div>

            <label><i class="fab fa-facebook me-1"></i> ফেসবুক আইডি লিঙ্ক:</label>
            <input type="url" name="facebook" value="<%= member.facebook %>" placeholder="https://facebook.com/username">

            <div class="grid">
                <div>
                    <label>বর্তমান ঠিকানা:</label>
                    <textarea name="present_address" rows="2"><%= member.present_address %></textarea>
                </div>
                <div>
                    <label>স্থায়ী ঠিকানা:</label>
                    <textarea name="permanent_address" rows="2"><%= member.permanent_address %></textarea>
                </div>
            </div>

            <div class="grid">
                <div>
                    <label>ওয়ার্ডের নাম:</label>
                    <input type="text" name="ward" value="<%= member.ward %>">
                </div>
                <div>
                    <label>উপশাখার নাম:</label>
                    <input type="text" name="branch" value="<%= member.branch %>">
                </div>
            </div>

            <div class="grid">
                <div>
                    <label>অভিভাবকের ফোন নম্বর:</label>
                    <input type="text" name="guardian_phone" value="<%= member.guardian_phone %>">
                </div>
                <div>
                    <label style="color: #fbbf24;"><i class="fas fa-key me-1"></i> গোপন কোড (পাসওয়ার্ড):</label>
                    <input type="text" name="password" value="<%= member.password %>" required>
                </div>
            </div>

            <div class="grid">
                <div>
                    <label>দায়িত্ব:</label>
                    <select name="responsibility">
                        <% ['থানা সভাপতি','থানা সেক্রেটারি','থানা সাংগঠনিক সম্পাদক','থানা বায়তুলমাল সম্পাদক','থানা সেক্রেটারিয়েট','ওয়ার্ড সভাপতি','ওয়ার্ড সেক্রেটারি','ওয়ার্ড সাংগঠনিক সম্পাদক','ওয়ার্ড বায়তুলমাল সম্পাদক','ওয়ার্ড সেক্রেটারিয়েট','উপশাখা সভাপতি','উপশাখা সেক্রেটারি','উপশাখা সাংগঠনিক সম্পাদক','উপশাখা বায়তুলমাল সম্পাদক','উপশাখা সেক্রেটারিয়েট'].forEach(opt => { %>
                            <option value="<%= opt %>" <%= member.responsibility === opt ? 'selected' : '' %>><%= opt %></option>
                        <% }) %>
                    </select>
                </div>
            </div>

            <label>শিক্ষা স্তর:</label>
            <select name="edu" onchange="toggleBox(this, 'eduO')">
                <% ['৫ম শ্রেণি','৬ষ্ঠ শ্রেণি','৭ম শ্রেণি','৮ম শ্রেণি','৯ম শ্রেণি','১০ম শ্রেণি','একাদশ শ্রেণি','দ্বাদশ শ্রেণি','অনার্স ১ম বর্ষ','অনার্স ২য় বর্ষ','অনার্স ৩য় বর্ষ','অনার্স ৪র্থ বর্ষ','মাস্টার্স','অন্যান্য'].forEach(opt => { %>
                    <option value="<%= opt %>" <%= member.edu === opt ? 'selected' : '' %>><%= opt %></option>
                <% }) %>
            </select>
            <div id="eduO" class="other-box <%= (member.edu && !['৫ম শ্রেণি','৬ষ্ঠ শ্রেণি','৭ম শ্রেণি','৮ম শ্রেণি','৯ম শ্রেণি','১০ম শ্রেণি','একাদশ শ্রেণি','দ্বাদশ শ্রেণি','অনার্স ১ম বর্ষ','অনার্স ২য় বর্ষ','অনার্স ৩য় বর্ষ','অনার্স ৪র্থ বর্ষ','মাস্টার্স'].includes(member.edu)) ? '' : 'd-none' %>">
                <input type="text" name="edu_other" value="<%= member.edu %>" placeholder="শিক্ষার বিস্তারিত...">
            </div>

            <label>শিক্ষা প্রতিষ্ঠান:</label>
            <select name="inst" onchange="toggleBox(this, 'instO')">
                <% ['প্রাথমিক বিদ্যালয়','মাধ্যমিক বিদ্যালয়','কওমী মাদ্রাসা','ইবতেদায়ী মাদ্রাসা','দাখিল মাদ্রাসা','ফাজিল মাদ্রাসা','আলিম মাদ্রাসা','কামিল মাদ্রাসা','কলেজ','বিশ্ববিদ্যালয় (সরকারী)','বিশ্ববিদ্যালয় (বেসরকারী)','মেডিকেল কলেজ','ডেন্টাল কলেজ','নার্সিং কলেজ','কৃষি বিশ্ববিদ্যালয়','পলিটেকনিক ইন্সটিটিউট','ইঞ্জিনিয়ারিং কলেজ','ইঞ্জিনিয়ারিং বিশ্ববিদ্যালয়','অন্যান্য'].forEach(opt => { %>
                    <option value="<%= opt %>" <%= member.inst === opt ? 'selected' : '' %>><%= opt %></option>
                <% }) %>
            </select>
            <div id="instO" class="other-box <%= (member.inst && !['প্রাথমিক বিদ্যালয়','মাধ্যমিক বিদ্যালয়','কওমী মাদ্রাসা','ইবতেদায়ী মাদ্রাসা','দাখিল মাদ্রাসা','ফাজিল মাদ্রাসা','আলিম মাদ্রাসা','কামিল মাদ্রাসা','কলেজ','বিশ্ববিদ্যালয় (সরকারী)','বিশ্ববিদ্যালয় (বেসরকারী)','মেডিকেল কলেজ','ডেন্টাল কলেজ','নার্সিং কলেজ','কৃষি বিশ্ববিদ্যালয়','পলিটেকনিক ইন্সটিটিউট','ইঞ্জিনিয়ারিং কলেজ','ইঞ্জিনিয়ারিং বিশ্ববিদ্যালয়'].includes(member.inst)) ? '' : 'd-none' %>">
                <input type="text" name="inst_other" value="<%= member.inst %>" placeholder="প্রতিষ্ঠানের নাম...">
            </div>

            <label>মন্তব্য:</label>
            <textarea name="comment" rows="3" placeholder="জনশক্তি সম্পর্কে বিশেষ তথ্য..."><%= member.comment %></textarea>

            <div style="display: flex; align-items: center; gap: 10px; margin: 15px 0 5px; background: rgba(251,191,36,0.08); border: 1px solid rgba(251,191,36,0.3); border-radius: 10px; padding: 12px 15px;">
                <i class="fas fa-coins" style="color: #fbbf24; font-size: 20px;"></i>
                <div style="flex: 1;">
                    <label style="margin: 0; color: #fbbf24; font-size: 13px; font-weight: 700;">বায়তুলমাল ধার্য (মাসিক, টাকায়)</label>
                    <input type="number" name="baitul_mal_amount" value="<%= member.baitul_mal_amount || 0 %>" placeholder="০" min="0" step="0.5" style="margin: 5px 0 0; background: rgba(0,0,0,0.4); border-color: rgba(251,191,36,0.5); color: #fbbf24; font-weight: 700; font-size: 15px;">
                </div>
            </div>

            <div style="margin-top: 30px; background: rgba(251,191,36,0.06); border: 1px solid rgba(251,191,36,0.25); border-radius: 15px; padding: 22px;">
                <h3 style="color: #fbbf24; margin-bottom: 8px; font-size: 1.1rem; display: flex; align-items: center; gap: 10px;">
                    <i class="fas fa-calendar-check"></i> বায়তুলমাল পরিশোধ (১২ মাস)
                </h3>
                <p style="font-size: 13px; color: #94a3b8; margin-bottom: 18px;">ধার্য: <strong style="color: #fbbf24;"><%= member.baitul_mal_amount || 0 %> টাকা/মাস</strong> &mdash; ক্লিক করে টিক (✓) বা ক্রস (✕) দিন, তারপর নিচে আপডেট বাটনে ক্লিক করুন।</p>

                <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;">
                    <% const monthNames = ['জানুয়ারি','ফেব্রুয়ারি','মার্চ','এপ্রিল','মে','জুন','জুলাই','আগস্ট','সেপ্টেম্বর','অক্টোবর','নভেম্বর','ডিসেম্বর']; %>
                    <% for(let i = 0; i < 12; i++) { %>
                        <% const paid = member.baitul_mal_payment && member.baitul_mal_payment[i]; %>
                        <label class="month-label <%= paid ? 'paid' : '' %>" id="lbl_<%= i %>">
                            <span><%= paid ? '✓' : '✕' %></span>
                            <span><%= monthNames[i] %></span>
                            <input type="checkbox" name="month_<%= i %>" <%= paid ? 'checked' : '' %>
                                onchange="updateLabel(this, <%= i %>)"
                                style="display: none;">
                        </label>
                    <% } %>
                </div>
            </div>

            <label style="margin-top: 20px; display: block;">জনশক্তির ছবি:</label>
            <div class="current-photo">
                <img src="<%= member.photo %>" alt="Current" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover; border: 2px solid #00d2ff;">
                <div style="font-size: 12px; color: #94a3b8;">বর্তমান ছবি দেখা যাচ্ছে। পরিবর্তন করতে চাইলে নিচে ফাইল সিলেক্ট করুন।</div>
            </div>
            <input type="file" name="photo" style="margin-top: 10px;">

            <button type="submit" class="btn" style="margin-top: 25px;"><i class="fas fa-save me-2"></i>আপডেট নিশ্চিত করুন</button>
            <a href="/admin" style="display:block; text-align:center; margin-top:15px; color:#94a3b8; text-decoration:none; font-size: 14px;">
                <i class="fas fa-times me-1"></i> বাতিল করুন
            </a>
        </form>
    </div>

    
    <script>
        function toggleBox(select, id) {
            document.getElementById(id).style.display = (select.value === 'অন্যান্য') ? 'block' : 'none';
        }
        function updateLabel(checkbox, idx) {
            const lbl = document.getElementById('lbl_' + idx);
            const icon = lbl.querySelector('span:first-child');
            const text = lbl.querySelector('span:last-of-type');
            if (checkbox.checked) {
                lbl.style.background = 'rgba(16,185,129,0.2)';
                lbl.style.border = '2px solid #10b981';
                icon.textContent = '✓';
                text.style.color = '#10b981';
            } else {
                lbl.style.background = 'rgba(239,68,68,0.1)';
                lbl.style.border = '2px solid rgba(239,68,68,0.4)';
                icon.textContent = '✕';
                text.style.color = '#ef4444';
            }
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
