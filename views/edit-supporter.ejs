<!DOCTYPE html>
<html lang="bn">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>শুভাকাঙ্ক্ষী তথ্য পরিবর্তন | রূপগঞ্জ পশ্চিম</title>
    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            font-family: 'Hind Siliguri', sans-serif;
            background: #050a0e;
            color: white;
            min-height: 100vh;
        }

        .edit-card {
            background: rgba(30, 41, 59, 0.4);
            backdrop-filter: blur(15px);
            padding: 30px;
            border-radius: 20px;
            max-width: 700px;
            margin: 40px auto;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        label {
            display: block;
            margin-top: 15px;
            color: #94a3b8;
            font-size: 14px;
        }

        input,
        select,
        textarea {
            width: 100%;
            padding: 12px;
            margin: 5px 0;
            border-radius: 10px;
            background: #0f172a;
            color: white;
            border: 1px solid #334155;
            outline: none;
        }

        .btn-update {
            background: linear-gradient(45deg, #10b981, #059669);
            color: white;
            border: none;
            padding: 15px;
            border-radius: 10px;
            width: 100%;
            font-weight: bold;
            margin-top: 25px;
        }

        .current-photo {
            display: flex;
            align-items: center;
            gap: 15px;
            background: rgba(255, 255, 255, 0.05);
            padding: 10px;
            border-radius: 10px;
            margin-top: 5px;
        }

        @media (max-width: 600px) {
            .grid {
                grid-template-columns: 1fr;
                gap: 0;
            }
        }
    </style>
</head>

<body>
    <%- include('partials/main-nav') %>
        <div class="edit-card">
            <h2 style="text-align:center; color:#10b981; margin-bottom:25px;">
                <i class="fas fa-user-edit"></i> শুভাকাঙ্ক্ষী তথ্য আপডেট
            </h2>

            <form action="/admin/update-supporter/<%= supporter.id %>" method="POST" enctype="multipart/form-data">
                <div class="grid">
                    <div>
                        <label>নাম:</label>
                        <input type="text" name="name" value="<%= supporter.name %>" required>
                    </div>
                    <div>
                        <label>ফোন নম্বর:</label>
                        <input type="text" name="phone" value="<%= supporter.phone %>" required>
                    </div>
                </div>

                <div class="grid">
                    <div>
                        <label>পেশা:</label>
                        <input type="text" name="profession" value="<%= supporter.profession %>">
                    </div>
                    <div>
                        <label style="color: #fbbf24;">গোপন কোড (পাসওয়ার্ড):</label>
                        <input type="text" name="password" value="<%= supporter.password %>" required>
                    </div>
                </div>

                <label>ঠিকানা:</label>
                <textarea name="address" rows="2"><%= supporter.address %></textarea>

                <label>ফেসবুক আইডি লিঙ্ক:</label>
                <input type="url" name="facebook" value="<%= supporter.facebook %>">

                <div
                    style="display: flex; align-items: center; gap: 10px; margin: 15px 0; background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.3); border-radius: 10px; padding: 12px 15px;">
                    <i class="fas fa-coins" style="color: #10b981; font-size: 20px;"></i>
                    <div style="flex: 1;">
                        <label style="margin: 0; color: #10b981; font-size: 13px; font-weight: 700;"> মাসিক বায়তুলমাল
                            ধার্য</label>
                        <input type="number" name="target_amount" value="<%= supporter.target_amount || 0 %>"
                            style="margin: 5px 0 0; background: rgba(0,0,0,0.4); border-color: rgba(16,185,129,0.5); color: #10b981;">
                    </div>
                </div>

                <label>বর্তমান ছবি:</label>
                <div class="current-photo">
                    <img src="<%= supporter.photo %>" alt="Current"
                        style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover; border: 2px solid #10b981;">
                    <div style="font-size: 12px; color: #94a3b8;">ছবি পরিবর্তন করতে নিচের ফাইল সিলেক্ট করুন।</div>
                </div>
                <input type="file" name="photo" style="margin-top: 10px;">

                <button type="submit" class="btn-update"><i class="fas fa-save me-2"></i>আপডেট সংরক্ষণ করুন</button>
                <a href="/admin"
                    style="display:block; text-align:center; margin-top:15px; color:#94a3b8; text-decoration:none; font-size: 14px;">বাতিল
                    করুন</a>
            </form>
        </div>
</body>

</html>