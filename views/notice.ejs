<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= notice.title %> | নোটিশ</title>
     <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;600;700&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* notice.ejs specific styles only */
        .notice-container-main { max-width: 860px; margin: auto; margin-top: 3rem; margin-bottom: 3rem; }
        .detail-glass-card { background: rgba(255,255,255,0.05); backdrop-filter: blur(15px); border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; padding: 40px; box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3); }
        .badge-custom { background-color: #84cc16; color: #000; padding: 6px 12px; border-radius: 20px; font-weight: bold; font-size: 0.85rem; }
        .meta-text { color: #cbd5e1; font-size: 0.95rem; margin-top: 15px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 20px; margin-bottom: 25px; }
        .notice-content { font-size: 1.15rem; line-height: 1.8; color: #e2e8f0; white-space: pre-wrap; word-wrap: break-word; }
        .back-btn { display: inline-flex; align-items: center; color: #f8fafc; background: rgba(255,255,255,0.1); padding: 10px 20px; border-radius: 30px; text-decoration: none; transition: 0.3s; margin-top: 40px; }
        .back-btn:hover { background: #84cc16; color: #000; }
    </style>
</head>
<body>
    <%- include('partials/main-nav') %>

    <div class="notice-container-main">
        <div class="detail-glass-card" style="border-top: 5px solid #84cc16;">
            <div class="d-flex align-items-center mb-3">
                <span class="badge-custom"><i class="fas fa-bullhorn me-2"></i>অফিশিয়াল নোটিশ</span>
            </div>
            <h1 class="fw-bold mb-2"><%= notice.title %></h1>
            <div class="meta-text">
                <i class="far fa-calendar-alt me-2"></i>প্রকাশিত: <strong><%= notice.date || 'সাম্প্রতিক' %></strong>
                <span class="mx-3">|</span>
                <i class="far fa-eye me-2"></i>দৃশ্যমান: <strong><%= notice.visibility %></strong>
            </div>
            
            <div class="notice-content"><%= notice.content %></div>
            
            <a href="/notices" class="back-btn"><i class="fas fa-arrow-left me-2"></i>সকল নোটিশে ফিরে যান</a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>