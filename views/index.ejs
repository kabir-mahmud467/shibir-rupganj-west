<!DOCTYPE html>
<html lang="bn">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <%- include('partials/seo') %>
        <title>হোম | বাংলাদেশ ইসলামী ছাত্রশিবির - রূপগঞ্জ পশ্চিম</title>
        <!-- Scripts and Meta tags -->

        <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;600;700&display=swap"
            rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

        <!-- User defined styles -->

        <style>
            /* index.ejs specific styles only */
            .hero-title {
                font-size: 3.5rem;
                font-weight: 800;
                background: linear-gradient(to bottom, #ffffff 40%, #a0a0a0 100%);
                -webkit-background-clip: text;
                background-clip: text;
                -webkit-text-fill-color: transparent;
                margin-bottom: 20px;
            }

            .quick-btn-grid {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 15px;
                margin: 40px 0;
            }

            @media (min-width: 768px) {
                .quick-btn-grid {
                    grid-template-columns: repeat(5, 1fr);
                }
            }

            .q-btn {
                background: rgba(255, 255, 255, 0.03);
                border: 1px solid rgba(255, 255, 255, 0.1);
                padding: 30px 15px;
                border-radius: 20px;
                text-align: center;
                color: #ffffff !important;
                text-decoration: none;
                transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                position: relative;
                overflow: hidden;
            }

            .q-btn:hover {
                background: rgba(16, 185, 129, 0.15);
                border-color: var(--accent-yellow);
                transform: translateY(-10px);
                box-shadow: 0 15px 30px rgba(0, 0, 0, 0.5);
            }

            .q-btn::before {
                content: '';
                position: absolute;
                top: -50%;
                left: -50%;
                width: 200%;
                height: 200%;
                background: radial-gradient(circle, rgba(255, 255, 255, 0.05) 0%, transparent 70%);
                transition: 0.5s;
            }

            /* নোটিশ বোর্ড এনিমেশন */
            .notice-container {
                height: 260px;
                overflow: hidden;
            }

            .hero-banner {
                position: relative;
                overflow: hidden;
                margin-bottom: 40px;
                border-radius: 24px;
                border: 1px solid rgba(255, 255, 255, 0.12);
                background: rgba(5, 10, 8, 0.45);
            }

            .hero-banner::before {
                content: '';
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at top right, rgba(0, 255, 144, 0.18), transparent 35%);
                pointer-events: none;
            }

            #threeCanvas {
                position: absolute;
                inset: 0;
                width: 100%;
                height: 100%;
                z-index: 0;
            }

            .hero-area {
                position: relative;
                z-index: 1;
                padding: 40px 30px;
            }

            .hero-slide {
                margin-top: 30px;
                padding: 20px;
                background: rgba(0, 0, 0, 0.34);
                border-radius: 18px;
                border: 1px solid rgba(255, 255, 255, 0.12);
                color: #f8f8f8;
            }

            .hero-slide .slide-title {
                color: #ffeb3b;
            }

            .floating-labels {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
                gap: 15px;
                margin-top: 35px;
            }

            .float-chip {
                background: rgba(255, 255, 255, 0.06);
                border: 2px solid rgba(255, 255, 255, 0.12);
                padding: 18px 16px;
                border-radius: 18px;
                text-align: center;
                font-size: 0.95rem;
                font-weight: 600;
                animation: floatUp 8s ease-in-out infinite;
                transition: 0.3s ease;
                color: #ffffff;
            }

            .float-chip:hover {
                transform: translateY(-5px);
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
            }

            .float-chip:nth-child(1) {
                background: rgba(0, 129, 68, 0.2);
                border-color: #00b366;
                color: #7fff9f;
                animation-delay: 0s;
            }

            .float-chip:nth-child(2) {
                background: rgba(0, 99, 58, 0.2);
                border-color: #009944;
                color: #66d9a0;
                animation-delay: 1.2s;
            }

            .float-chip:nth-child(3) {
                background: rgba(0, 129, 68, 0.2);
                border-color: #00b366;
                color: #7fff9f;
                animation-delay: 2.4s;
            }

            .float-chip:nth-child(4) {
                background: rgba(0, 99, 58, 0.2);
                border-color: #009944;
                color: #66d9a0;
                animation-delay: 3.6s;
            }

            .float-chip:nth-child(5) {
                background: rgba(0, 129, 68, 0.2);
                border-color: #00b366;
                color: #7fff9f;
                animation-delay: 4.8s;
            }

            @keyframes floatUp {

                0%,
                100% {
                    transform: translateY(0);
                }

                50% {
                    transform: translateY(-10px);
                }
            }

            @media (max-width: 768px) {
                .hero-title {
                    font-size: 2.2rem;
                }
            }

            /* Modern Mesh Gradient Background */
            body {
                background-color: #050a0e;
                background-image:
                    radial-gradient(at 0% 0%, rgba(0, 129, 68, 0.15) 0px, transparent 50%),
                    radial-gradient(at 100% 100%, rgba(59, 130, 246, 0.15) 0px, transparent 50%),
                    radial-gradient(at 100% 0%, rgba(245, 158, 11, 0.05) 0px, transparent 50%);
                background-attachment: fixed;
            }

            .btn-hover {
                transition: all 0.3s ease;
            }

            .btn-hover:hover {
                transform: translateY(-8px);
                background: rgba(255, 255, 255, 0.08) !important;
                border-color: rgba(255, 255, 255, 0.3) !important;
                box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
            }

            .feature-icon {
                width: 60px;
                height: 60px;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 15px;
                margin-bottom: 20px;
                font-size: 1.5rem;
            }

            .section-tag {
                display: inline-block;
                padding: 8px 20px;
                background: rgba(255, 255, 255, 0.05);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 50px;
                color: var(--accent-yellow);
                font-weight: 700;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 2px;
                margin-bottom: 20px;
            }

            .vision-stat-card {
                background: rgba(255, 255, 255, 0.02);
                border: 1px solid rgba(255, 255, 255, 0.05);
                padding: 30px;
                border-radius: 20px;
                text-align: center;
            }
        </style>
</head>

<body>



    <%- include('partials/main-nav') %>

        <div class="hero-banner">
            <canvas id="threeCanvas"></canvas>
            <div class="hero-area container-lg">
                <h1 class="hero-title">সত্য ও সুন্দরের পথে কাফেলা</h1>
                <p class="text-light opacity-75 fs-5">রূপগঞ্জ পশ্চিম থানা শাখার সব তথ্য, কর্মসূচি ও লাইব্রেরি এক জায়গায়।
                </p>
                <div class="hero-slide position-relative">
                    <div id="mainHeroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel"
                        data-bs-interval="3000">
                        <div class="carousel-inner">
                            <% if (slides && slides.length> 0) { %>
                                <% slides.forEach((slide, idx)=> { %>
                                    <div class="carousel-item <%= idx === 0 ? 'active' : '' %>">
                                        <% if (slide.imageUrl) { %>
                                            <div>
                                                <img src="<%= slide.imageUrl %>" class="img-fluid rounded mb-3 w-100"
                                                    style="max-height: 400px; object-fit: cover; background: rgba(0,0,0,0.5);"
                                                    alt="<%= slide.title %>">
                                            </div>
                                            <% } %>
                                                <h3 class="slide-title">
                                                    <%= slide.title %>
                                                </h3>
                                                <p class="mb-2">
                                                    <%= slide.caption
                                                        || 'হোম পেজ স্লাইডটি অ্যাড করে নতুন তথ্য প্রকাশ করুন।' %>
                                                </p>
                                    </div>
                                    <% }) %>
                                        <% } else { %>
                                            <div class="carousel-item active">
                                                <h3 class="slide-title">সাম্প্রতিক প্রোগ্রামসমূহ </h3>
                                                <p class="mb-0"></p>
                                            </div>
                                            <% } %>
                        </div>
                        <% if (slides && slides.length> 1) { %>
                            <button class="carousel-control-prev" type="button" data-bs-target="#mainHeroCarousel"
                                data-bs-slide="prev" style="width: 8%;">
                                <span class="carousel-control-prev-icon" aria-hidden="true"
                                    style="background-color: rgba(0,0,0,0.6); border-radius: 50%; padding: 20px; background-size: 50%;"></span>
                                <span class="visually-hidden">Previous</span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#mainHeroCarousel"
                                data-bs-slide="next" style="width: 8%;">
                                <span class="carousel-control-next-icon" aria-hidden="true"
                                    style="background-color: rgba(0,0,0,0.6); border-radius: 50%; padding: 20px; background-size: 50%;"></span>
                                <span class="visually-hidden">Next</span>
                            </button>
                            <% } %>
                    </div>
                </div>
            </div>
        </div>

        <div class="container mt-5">
            <div class="quick-btn-grid mb-5">
                <a href="/form" class="q-btn">
                    <i class="fas fa-file-signature text-success fs-2 mb-3"></i>
                    <span class="fw-bold">সমর্থক ফরম</span>
                </a>
                <a href="/library" class="q-btn">
                    <i class="fas fa-book-reader text-info fs-2 mb-3"></i>
                    <span class="fw-bold">অনলাইন লাইব্রেরী</span>
                </a>
                <a href="/archive" class="q-btn">
                    <i class="fas fa-camera-retro text-danger fs-3 mb-3"></i>
                    <span class="fw-bold">আর্কাইভ</span>
                </a>
                <a href="/history" class="q-btn">
                    <i class="fas fa-monument text-warning fs-3 mb-3"></i>
                    <span class="fw-bold">ইতিহাস</span>
                </a>
                <a href="#"
                    id="installAppBtn"
                    class="q-btn pwa-install-trigger"
                    data-install-hint-target="#installAppHint"
                    aria-label="Install app">
                    <i class="fab fa-android text-primary fs-2 mb-3"></i>
                    <span class="fw-bold">অ্যাপ ইনস্টল</span>
                    <small id="installAppHint" class="text-light opacity-75 mt-2">Install করতে ক্লিক করুন</small>
                </a>
            </div>

            <div class="row g-4 mb-5 position-relative overflow-hidden" style="border-radius: 24px;">
                <canvas id="noticeCanvas"
                    style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; opacity: 0.3;"></canvas>
                <div class="col-lg-12 position-relative" style="z-index: 1;">
                    <div class="glass-card p-5" style="border-top: 4px solid var(--accent-yellow);">
                        <div class="d-flex justify-content-between align-items-center mb-5">
                            <div>
                                <span class="section-tag mb-2">Live Updates</span>
                                <h3 class="text-white fw-bold m-0"><i class="fas fa-bolt text-warning me-2"></i> সর্বশেষ
                                    নোটিশ ও সংবাদ</h3>
                            </div>
                            <a href="/notices" class="btn btn-warning rounded-pill px-4 fw-bold shadow-sm">সকল নোটিশ <i
                                    class="fas fa-arrow-right ms-1"></i></a>
                        </div>
                        <div class="row g-4">
                            <% if(notices && notices.length> 0) { %>
                                <% notices.slice(0, 4).forEach((n, idx)=> { %>
                                    <div class="col-md-6">
                                        <div class="glass-card p-0 overflow-hidden h-100 btn-hover"
                                            style="border: 1px solid rgba(255,255,255,0.05); background: rgba(255,255,255,0.01);">
                                            <div class="p-4">
                                                <div class="d-flex align-items-center gap-3 mb-3">
                                                    <div class="bg-warning text-dark fw-bold rounded px-3 py-1 small">
                                                        <%= n.date ? n.date.split(' ')[0] : ' NEW' %>
                                                    </div>
                                                    <span class="text-light opacity-75 small">/ প্রকাশিত সংবাদ</span>
                                                </div>
                                                <h5 class="text-white fw-bold mb-3" style="line-height: 1.5;">
                                                    <%= n.title %>
                                                </h5>
                                                <p class="text-light opacity-75 small mb-4">
                                                    <%= n.content.substring(0, 110) %>...
                                                </p>
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <a href="/notice/<%= n._id %>"
                                                        class="btn btn-link text-warning p-0 text-decoration-none fw-bold small">
                                                        বিস্তারিত পড়ুন <i class="fas fa-chevron-right ms-1"
                                                            style="font-size: 0.7rem;"></i>
                                                    </a>
                                                    <div class="text-light opacity-75 small"><i
                                                            class="far fa-clock me-1"></i> সাম্প্রতিক সংবাদ</div>
                                                </div>
                                            </div>
                                            <div
                                                style="height: 4px; background: linear-gradient(to right, transparent, var(--accent-yellow), transparent); opacity: 0.3;">
                                            </div>
                                        </div>
                                    </div>
                                    <% }) %>
                                        <% } else { %>
                                            <div class="col-12 py-5 text-center">
                                                <i class="fas fa-folder-open display-4 text-muted mb-3"></i>
                                                <p class="text-light opacity-75">বর্তমানে কোনো নোটিশ নেই।</p>
                                            </div>
                                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- New Stats Section -->
            <!--  <div class="row g-4 mb-5">
                <div class="col-md-3">
                    <div class="vision-stat-card">
                        <h4 class="text-success fw-bold">২৫০+</h4>
                        <p class="text-light opacity-85 small mb-0">সক্রিয় জনশক্তি</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="vision-stat-card">
                        <h4 class="text-info fw-bold">৫০+</h4>
                        <p class="text-light opacity-85 small mb-0">লাইব্রেরি বই</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="vision-stat-card">
                        <h4 class="text-warning fw-bold">১৫+</h4>
                        <p class="text-light opacity-85 small mb-0">সামাজিক প্রকল্প</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="vision-stat-card">
                        <h4 class="text-danger fw-bold">১০০%</h4>
                        <p class="text-light opacity-85 small mb-0">নৈতিক অঙ্গীকার</p>
                    </div>
                </div>
            </div>-->

            <!-- সংগঠনের লক্ষ্য ও উদ্দেশ্য (Official Content) -->
            <div class="row g-4 mb-5">
                <div class="col-lg-12">
                    <div class="glass-card p-5 text-center"
                        style="border-top: 4px solid #10b981; background: linear-gradient(to bottom, rgba(16, 185, 129, 0.05), transparent);">
                        <span class="section-tag">Target & Mission</span>
                        <h2 class="text-white fw-bold mb-4">আমাদের লক্ষ্য ও উদ্দেশ্য</h2>
                        <div class="row justify-content-center">
                            <div class="col-lg-9">
                                <p class="text-light fs-5 lh-base mb-4" style="font-weight: 300; opacity: 0.95;">
                                    "আল্লাহ প্রদত্ত ও রাসূল (সা.) প্রদর্শিত বিধান অনুযায়ী মানুষের সার্বিক জীবনের
                                    পুনর্বিন্যাস সাধন করে আল্লাহর সন্তোষ অর্জন।"
                                </p>
                                <hr class="w-25 mx-auto border-secondary opacity-25">
                                <p class="text-light opacity-60 small mt-3">বাংলাদেশ ইসলামী ছাত্রশিবির সংবিধান: ধারা ২
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- সংগঠনের পটভূমি ও রূপগঞ্জ পশ্চিম শাখার ইতিহাস -->
            <div class="row g-4 mb-5">
                <div class="col-lg-12">
                    <div class="glass-card p-5" style="border-left: 4px solid #10b981;">
                        <span class="section-tag">History & Context</span>
                        <div class="row">
                            <div class="col-lg-8">
                                <h2 class="text-white fw-bold mb-4">আমাদের পটভূমি ও রূপগঞ্জ পশ্চিম শাখা</h2>
                                <p class="text-light opacity-75 lh-lg">
                                    বাংলাদেশ ইসলামী ছাত্রশিবির ১৯৭৭ সালের ৬ই ফেব্রুয়ারি ঢাকা বিশ্ববিদ্যালয়ের
                                    কেন্দ্রীয় মসজিদে প্রতিষ্ঠার মাধ্যমে তার যাত্রা শুরু করে। এক সুদীর্ঘ ও কণ্টকাকীর্ণ
                                    পথ পাড়ি দিয়ে আজ ছাত্রশিবির দেশের ছাত্রসমাজের হৃদস্পন্দনে পরিণত হয়েছে।
                                    <br><br>
                                    রূপগঞ্জ পশ্চিম থানা শাখা নারায়ণগঞ্জের এক ঐতিহ্যবাহী ও সক্রিয় শাখা। এই এলাকার
                                    ছাত্রদের মাঝে ইসলামী শিক্ষা ও নৈতিক মূল্যবোধ ছড়িয়ে দিতে এই শাখা নিরলসভাবে কাজ করে
                                    যাচ্ছে। প্রতিষ্ঠালগ্ন থেকেই এই শাখা সাম্য, মানবিক মর্যাদা ও সামাজিক ন্যায়বিচার
                                    প্রতিষ্ঠায় অগ্রণী ভূমিকা পালন করছে।
                                </p>
                                <a href="/history" class="btn btn-outline-success mt-3 rounded-pill px-4">বিস্তারিত
                                    ইতিহাস পড়ুন</a>
                            </div>
                            <div class="col-lg-4 d-none d-lg-block">
                                <div class="p-4 glass-card text-center h-100 d-flex flex-column justify-content-center"
                                    style="border: 1px dashed rgba(255,255,255,0.1);">
                                    <div class="display-4 fw-bold text-success mb-2">১৯৭৭</div>
                                    <p class="text-light small text-uppercase letter-spacing-1">প্রতিষ্ঠা সাল</p>
                                    <hr class="w-25 mx-auto border-secondary">
                                    <div class="display-4 fw-bold text-success mb-2">নারায়ণগঞ্জ</div>
                                    <p class="text-light small text-uppercase letter-spacing-1">আমাদের গৌরব</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="position-relative overflow-hidden py-5 my-5"
                style="border-radius: 24px; background: rgba(0, 129, 68, 0.05); border: 1px solid rgba(255,255,255,0.05);">
                <canvas id="programCanvas"
                    style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; opacity: 0.4;"></canvas>
                <div class="position-relative" style="z-index: 1;">
                    <div class="text-center mb-5 px-3">
                        <span class="section-tag">Working Plan</span>
                        <h2 class="text-white fw-bold mb-2">৫ দফা কর্মসূচি</h2>
                        <p class="text-light opacity-75">আমাদের লক্ষ্য অর্জনে এক সুনির্দিষ্ট ও বিজ্ঞানসম্মত কর্মপন্থা
                        </p>
                    </div>

                    <div class="floating-labels px-3">
                        <a href="/program/dawah" class="float-chip text-decoration-none">
                            <i class="fas fa-bullhorn mb-2 d-block fs-4" style="color: #00b366;"></i>
                            ১. দাওয়াত
                        </a>
                        <a href="/program/organization" class="float-chip text-decoration-none">
