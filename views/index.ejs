    <style>
        :root {
            --primary-green: #008144;
            --dark-bg: #0a0f0d;
            --footer-bg: #051a0f;
            --glass-white: rgba(255, 255, 255, 0.08);
            --glass-border: rgba(255, 255, 255, 0.15);
            --accent-yellow: #ffb700;
        }

        body {
            font-family: 'Hind Siliguri', sans-serif;
            background: radial-gradient(circle at 10% 20%, #002b16, var(--dark-bg) 80%);
            color: #ffffff;
            font-weight: 500;
            min-height: 100vh;
            overflow-x: hidden;
            opacity: 1;
        }

        .glass-card {
            background: var(--glass-white);
            backdrop-filter: blur(15px);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            transition: 0.3s ease;
        }

        /* Navbar Style */
        .navbar { 
            background: rgba(10, 15, 13, 0.95); 
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--glass-border);
            padding: 12px 0;
        }

        .hero-title {
            font-size: 3.5rem;
            font-weight: 800;
            background: linear-gradient(to bottom, #ffffff 40%, #a0a0a0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 20px;
        }

        /* বাটন গ্রিড (মোবাইলে ২ কলাম, পিসিতে ৪ কলাম) */
        .quick-btn-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin: 40px 0;
        }

        @media (min-width: 768px) {
            .quick-btn-grid { grid-template-columns: repeat(4, 1fr); }
        }

        .q-btn {
            background: var(--glass-white);
            border: 1px solid var(--glass-border);
            padding: 25px 10px;
            border-radius: 18px;
            text-align: center;
            color: #ffffff !important;
            text-decoration: none;
            transition: 0.3s;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .q-btn:hover {
            background: rgba(0, 129, 68, 0.3);
            border-color: var(--accent-yellow);
            transform: translateY(-5px);
        }

        .q-btn i { font-size: 1.8rem; margin-bottom: 12px; }

        /* নোটিশ বোর্ড এনিমেশন */
        .notice-container { height: 260px; overflow: hidden; }
        .notice-container { min-height: 260px; }

        .hero-banner {
            position: relative;
            overflow: hidden;
            margin-bottom: 40px;
            border-radius: 24px;
            border: 1px solid rgba(255,255,255,0.12);
            background: rgba(5, 10, 8, 0.45);
        }
        .hero-banner::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at top right, rgba(0,255,144,0.18), transparent 35%);
            pointer-events: none;
        }
        #threeCanvas {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
        }
        .hero-area {
            position: relative;
            z-index: 1;
            padding: 40px 30px;
        }
        .hero-area h1, .hero-area p { position: relative; z-index: 1; }
        .hero-slide {
            margin-top: 30px;
            padding: 20px;
            background: rgba(0,0,0,0.34);
            border-radius: 18px;
            border: 1px solid rgba(255,255,255,0.12);
            color: #f8f8f8;
        }
        .hero-slide .slide-title { color: #ffeb3b; }
        .floating-labels {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 15px;
            margin-top: 35px;
        }
        .float-chip {
            background: rgba(255,255,255,0.06);
            border: 2px solid rgba(255,255,255,0.12);
            padding: 18px 16px;
            border-radius: 18px;
            text-align: center;
            font-size: 0.95rem;
            font-weight: 600;
            animation: floatUp 8s ease-in-out infinite;
            transition: 0.3s ease;
            color: #ffffff;
        }
        .float-chip:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.3);
        }
        .float-chip:nth-child(1) {
            background: rgba(0, 129, 68, 0.2);
            border-color: #00b366;
            color: #7fff9f;
            animation-delay: 0s;
        }
        .float-chip:nth-child(2) {
            background: rgba(0, 99, 58, 0.2);
            border-color: #009944;
            color: #66d9a0;
            animation-delay: 1.2s;
        }
        .float-chip:nth-child(3) {
            background: rgba(0, 129, 68, 0.2);
            border-color: #00b366;
            color: #7fff9f;
            animation-delay: 2.4s;
        }
        .float-chip:nth-child(4) {
            background: rgba(0, 99, 58, 0.2);
            border-color: #009944;
            color: #66d9a0;
            animation-delay: 3.6s;
        }
        .float-chip:nth-child(5) {
            background: rgba(0, 129, 68, 0.2);
            border-color: #00b366;
            color: #7fff9f;
            animation-delay: 4.8s;
        }
        @keyframes floatUp { 0%,100%{transform: translateY(0);}50%{transform: translateY(-10px);} }

        /* dushibir.org Style Footer */
        .main-footer {
            background: var(--footer-bg);
            border-top: 4px solid var(--primary-green);
            color: #fff;
            padding: 60px 0 0px;
            margin-top: 80px;
        }

        .footer-title {
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: 25px;
            position: relative;
            color: var(--accent-yellow);
        }

        .footer-links { list-style: none; padding: 0; }
        .footer-links li { margin-bottom: 12px; }
        .footer-links a {
            color: #cbd5e0;
            text-decoration: none;
            transition: 0.3s;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
        }

        .footer-links a:hover { color: var(--accent-yellow); padding-left: 8px; }

        .social-links { display: flex; gap: 12px; margin-top: 20px; }
        .social-icon {
            width: 38px; height: 38px;
            background: rgba(255, 255, 255, 0.1);
            display: flex; align-items: center; justify-content: center;
            border-radius: 50%; color: #fff; text-decoration: none; transition: 0.3s;
        }
        .social-icon:hover { background: var(--primary-green); transform: translateY(-3px); }

        .copyright-area {
            background-color: #03110a;
            padding: 20px 0;
            margin-top: 50px;
            border-top: 1px solid rgba(255,255,255,0.05);

        }

        @media (max-width: 768px) {
            .hero-title { font-size: 2.2rem; }
        }
    </style>
</head>

<body>

    <!-- EMBER_CLI_FASTBOOT_BODY -->

    <%- include('partials/main-nav') %>

    <div class="hero-banner" <% if (slides && slides.length > 0) { %> style="background-image: url('<%= slides[0].imageUrl %>'); background-size: cover; background-position: center; background-blend-mode: overlay;" <% } %>>
        <canvas id="threeCanvas"></canvas>
        <div class="hero-area container-lg">
            <h1 class="hero-title">সত্য ও সুন্দরের পথে কাফেলা</h1>
            <p class="text-light opacity-75 fs-5">রূপগঞ্জ পশ্চিম থানা শাখার সব তথ্য, কর্মসূচি ও লাইব্রেরি এক জায়গায়।</p>
            <div class="hero-slide">
                <% if (slides && slides.length > 0) { %>
                    <% slides.forEach((slide, idx) => { %>
                        <div class="slide-item" style="display:<%= idx === 0 ? 'block' : 'none' %>;" data-slide-index="<%= idx %>">
                            <h3 class="slide-title"><%= slide.title %></h3>
                            <p class="mb-2"><%= slide.caption || 'হোম পেজ স্লাইডটি অ্যাড করে নতুন তথ্য প্রকাশ করুন।' %></p>
                            <% if (slide.link) { %>
                                <a href="<%= slide.link %>" target="_blank" class="text-warning text-decoration-none">লিংক দেখুন →</a>
                            <% } %>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div>
                        <h3 class="slide-title">সাম্প্রতিক প্রোগ্রামসমূহ </h3>
                        <p class="mb-0"></p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <div class="container mt-5">
        <div class="glass-card p-4 mb-5 text-center" style="border-left: 5px solid var(--accent-yellow);">
            <div id="quoteCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <h5 class="fw-bold text-white">"বাতিল যখন সুসংগঠিত হয়, তখন হকপন্থীদের পরাজয়ের প্রধান কারণ হয় তাদের অসংগঠিত থাকা।"</h5>
                        <p class="text-warning mb-0 mt-2">— সায়্যেদ আবুল আ’লা মওদূদী (র)</p>
                    </div>
                    <div class="carousel-item">
                        <h5 class="fw-bold text-white">"যদি ইসলামকে বিজয়ী করতে চান, তবে আগে নিজেদের চরিত্রে ইসলামের প্রতিফলন ঘটান।"</h5>
                        <p class="text-warning mb-0 mt-2">— শহীদ আব্দুল মালেক (র)</p>
                    </div>
                </div>
            </div>
        </div>

        <!--<div class="text-center mb-5">
            <h1 class="hero-title">সত্য ও সুন্দরের পথে কাফেলা</h1>--> 
            <div class="text-center mb-5 mt-5">
                <img src="https://www.dushibir.org/storage/setting_images/wKFhZtq3w8jQDZT9wLfeJJXeGW09yJss7WACq03k.png" alt="Logo" height="50" class="mb-3">
                <h2 class="text-white fw-bold mb-2"><i class="fas fa-tasks me-2" style="color: #00b366;"></i>আমাদের কর্মসূচি সমূহ</h2>
                <p class="text-light opacity-75">রূপগঞ্জ পশ্চিম শাখার মূল কর্মসূচি ক্ষেত্র</p>
            </div>

                <div class="floating-labels">
                    <div class="float-chip">দাওয়াত </div>
                    <div class="float-chip">সংগঠন </div>
                    <div class="float-chip">প্রশিক্ষণ </div>
                    <div class="float-chip">ইসলামী শিক্ষা আন্দোলন ও ছাত্র সমস্যার সমাধান </div>
                    <div class="float-chip">ইসলামী সমাজ বিনির্মাণ </div>
                </div>
                
                <div class="quick-btn-grid mt-5">
                    <a href="/form" class="q-btn">
                        <i class="fas fa-user-plus text-success"></i>
                        <span>সমর্থক ফরম</span>
                    </a>
                    <a href="/library" class="q-btn">
                        <i class="fas fa-book text-info"></i>
                        <span>অনলাইন লাইব্রেরী</span>
                    </a>
                    <a href="/archive" class="q-btn">
                        <i class="fas fa-bullhorn text-danger"></i>
                        <span>আর্কাইভ</span>
                    </a>
                    <a href="/history" class="q-btn">
                        <i class="fas fa-history text-warning"></i>
                        <span>ইতিহাস</span>
                    </a>
                </div>

                <div class="glass-card p-4 mt-4 text-start" style="border-left: 4px solid #84cc16;">
                    <h5 class="text-white fw-bold">আমরা এখন পর্যন্ত যা করেছি</h5>
                    <div class="row g-3 mt-3">
                        <% if (homeStats && homeStats.length > 0) { %>
                            <% homeStats.forEach(stat => { %>
                                <div class="col-md-3">
                                    <div class="float-chip" style="animation:none;"><strong><%= stat.value %></strong><br><small><%= stat.label %></small></div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="col-md-3">
                                <div class="float-chip" style="animation:none;">২৫০+ ছাত্র সমর্থক</div>
                            </div>
                            <div class="col-md-3">
                                <div class="float-chip" style="animation:none;">১২টি শিক্ষা কর্মসূচি</div>
                            </div>
                            <div class="col-md-3">
                                <div class="float-chip" style="animation:none;">৫০০+ লাইব্রেরি লিংক</div>
                            </div>
                            <div class="col-md-3">
                                <div class="float-chip" style="animation:none;">নিয়োজিত শাখা সেবা</div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mt-5">
            <div class="col-lg-12">
                <div class="glass-card p-5" style="border-left: 4px solid var(--accent-yellow);">
                    <h4 class="fw-bold mb-4 text-white"><i class="fas fa-newspaper text-success me-2"></i> সর্বশেষ আপডেট</h4>
                    <div class="row g-3">
                        <% if(notices && notices.length > 0) { %>
                            <% notices.slice(0, 4).forEach(n => { %>
                                <div class="col-md-6">
                                <div class="glass-card p-4 h-100">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="badge bg-success">সংবাদ</span>
                                        <small class="text-muted"><%= n.date %></small>
                                    </div>
                                    <h6 class="text-white fw-bold"><%= n.title %></h6>
                                    <p class="text-light small" style="color: #e0e0e0;"><%= n.content.substring(0, 90) %>...</p>
                                    <a href="/notice/<%= n._id %>" class="text-warning small text-decoration-none fw-bold">বিস্তারিত পড়ুন →</a>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="col-12"><p class="text-muted">আপাতত কোনো সংবাদ নেই।</p></div>
                    <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="main-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
