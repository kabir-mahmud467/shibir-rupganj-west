<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <title>হোম | রূপগঞ্জ পশ্চিম</title>
    <style>
        body { background: #020617; color: white; font-family: sans-serif; }
        .notice { border-left: 4px solid #f59e0b; background: rgba(245, 158, 11, 0.1); padding: 15px; margin-bottom: 10px; border-radius: 5px; }
    </style>
</head>
<body>
    <%- include('partials/nav', {user: user}) %>
    <div style="max-width:1000px; margin:20px auto; padding:20px;">
        <h2><i class="fas fa-bullhorn"></i> নোটিশবোর্ড</h2>
        <% notices.forEach(n => { %>
            <div class="notice">
                <strong><%= n.title %></strong> <small>(<%= n.date %>)</small>
                <p><%= n.content %></p>
            </div>
        <% }) %>

        <h2 style="margin-top:40px;"><i class="fas fa-book"></i> লাইব্রেরি</h2>
        <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap:15px;">
            <% resources.forEach(r => { %>
                <div style="background:#1e293b; padding:15px; border-radius:10px; text-align:center;">
                    <h4><%= r.title %></h4>
                    <a href="<%= r.url %>" style="color:#00d2ff;">ডাউনলোড/ওপেন</a>
                </div>
            <% }) %>
        </div>
    </div>
</body>
</html>