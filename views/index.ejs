        <script type="module">
            import * as THREE from "https://cdn.jsdelivr.net/npm/three@0.152.2/build/three.module.js";
            document.addEventListener('DOMContentLoaded', function () {
                (function () {
                    const canvas = document.getElementById('threeCanvas');
                    if (!canvas) return;

                    const scene = new THREE.Scene();
                    const camera = new THREE.PerspectiveCamera(50, canvas.clientWidth / canvas.clientHeight, 0.1, 1000);
                    camera.position.set(0, 0, 55);

                    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
                    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
                    renderer.setSize(canvas.clientWidth, canvas.clientHeight);

                    /* ── 1. STAR FIELD (multi-colour) ── */
                    const starCount = 600;
                    const starGeo = new THREE.BufferGeometry();
                    const starPos = new Float32Array(starCount * 3);
                    const starCol = new Float32Array(starCount * 3);
                    const starColors = [
                        [0.55, 1.0, 0.55],   // soft green
                        [1.0, 0.85, 0.2],    // gold
                        [1.0, 1.0, 1.0],    // white
                        [0.4, 0.9, 1.0],    // cyan
                    ];
                    for (let i = 0; i < starCount; i++) {
                        starPos[i * 3] = (Math.random() - 0.5) * 140;
                        starPos[i * 3 + 1] = (Math.random() - 0.5) * 140;
                        starPos[i * 3 + 2] = (Math.random() - 0.5) * 100;
                        const c = starColors[Math.floor(Math.random() * starColors.length)];
                        starCol[i * 3] = c[0];
                        starCol[i * 3 + 1] = c[1];
                        starCol[i * 3 + 2] = c[2];
                    }
                    starGeo.setAttribute('position', new THREE.BufferAttribute(starPos, 3));
                    starGeo.setAttribute('color', new THREE.BufferAttribute(starCol, 3));
                    const starMat = new THREE.PointsMaterial({
                        size: 0.35,
                        vertexColors: true,
                        transparent: true,
                        opacity: 0.9,
                        sizeAttenuation: true,
                    });
                    const stars = new THREE.Points(starGeo, starMat);
                    scene.add(stars);

                    /* ── 2. WIREFRAME ICOSAHEDRON ── */
                    const icoGeo = new THREE.IcosahedronGeometry(10, 1);
                    const icoMat = new THREE.MeshBasicMaterial({
                        color: 0x00e676,
                        wireframe: true,
                        transparent: true,
                        opacity: 0.18,
                    });
                    const ico = new THREE.Mesh(icoGeo, icoMat);
                    scene.add(ico);

                    /* ── 3. INNER SOLID ICO (glow core) ── */
                    const innerIcoGeo = new THREE.IcosahedronGeometry(6, 0);
                    const innerIcoMat = new THREE.MeshBasicMaterial({
                        color: 0x004d25,
                        transparent: true,
                        opacity: 0.25,
                    });
                    const innerIco = new THREE.Mesh(innerIcoGeo, innerIcoMat);
                    scene.add(innerIco);

                    /* ── 4. TORUS RINGS ── */
                    function makeTorus(r, tube, color, rx, ry) {
                        const geo = new THREE.TorusGeometry(r, tube, 12, 80);
                        const mat = new THREE.MeshBasicMaterial({
                            color,
                            transparent: true,
                            opacity: 0.12,
                            wireframe: false,
                        });
                        const mesh = new THREE.Mesh(geo, mat);
                        mesh.rotation.x = rx;
                        mesh.rotation.y = ry;
                        return mesh;
                    }
                    const ring1 = makeTorus(22, 0.25, 0x00ff88, Math.PI / 3, 0.3);
                    const ring2 = makeTorus(30, 0.18, 0xffcc00, Math.PI / 6, -0.5);
                    const ring3 = makeTorus(38, 0.14, 0x44ddff, -Math.PI / 4, 0.8);
                    scene.add(ring1, ring2, ring3);

                    /* ── 5. FLOATING SMALL DOTS (close foreground layer) ── */
                    const fgCount = 80;
                    const fgGeo = new THREE.BufferGeometry();
                    const fgPos = new Float32Array(fgCount * 3);
                    for (let i = 0; i < fgCount; i++) {
                        fgPos[i * 3] = (Math.random() - 0.5) * 60;
                        fgPos[i * 3 + 1] = (Math.random() - 0.5) * 40;
                        fgPos[i * 3 + 2] = (Math.random() - 0.5) * 20 + 15;
                    }
                    fgGeo.setAttribute('position', new THREE.BufferAttribute(fgPos, 3));
                    const fgMat = new THREE.PointsMaterial({ color: 0xffd700, size: 0.55, transparent: true, opacity: 0.7 });
                    const fgDots = new THREE.Points(fgGeo, fgMat);
                    scene.add(fgDots);

                    /* ── MOUSE PARALLAX ── */
                    let mouseX = 0, mouseY = 0;
                    document.addEventListener('mousemove', (e) => {
                        mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
                        mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
                    });

                    /* ── RESIZE ── */
                    const onResize = () => {
                        renderer.setSize(canvas.clientWidth, canvas.clientHeight);
                        camera.aspect = canvas.clientWidth / canvas.clientHeight;
                        camera.updateProjectionMatrix();
                    };
                    window.addEventListener('resize', onResize);

                    /* ── ANIMATION LOOP ── */
                    let clock = 0;
                    function animate() {
                        requestAnimationFrame(animate);
                        clock += 0.008;

                        // Stars slow drift
                        stars.rotation.y += 0.0005;
                        stars.rotation.x += 0.0002;

                        // Icosahedron rotation
                        ico.rotation.x += 0.003;
                        ico.rotation.y += 0.004;
                        innerIco.rotation.x -= 0.004;
                        innerIco.rotation.y -= 0.003;

                        // Pulsing ico scale
                        const pulse = 1 + 0.04 * Math.sin(clock * 2.5);
                        ico.scale.setScalar(pulse);

                        // Ring spin
                        ring1.rotation.z += 0.004;
                        ring2.rotation.z -= 0.003;
                        ring3.rotation.z += 0.002;

                        // Foreground dot float
                        fgDots.rotation.y += 0.001;

                        // Mouse parallax on camera
                        camera.position.x += (mouseX * 4 - camera.position.x) * 0.04;
                        camera.position.y += (-mouseY * 3 - camera.position.y) * 0.04;
                        camera.lookAt(scene.position);

                        renderer.render(scene, camera);
                    }
                    animate();
                })();

                (function () {
                    const canvas = document.getElementById('expectationsCanvas');
                    if (!canvas) return;

                    const scene = new THREE.Scene();
                    const camera = new THREE.PerspectiveCamera(45, canvas.clientWidth / canvas.clientHeight, 0.1, 1000);
                    camera.position.z = 40;

                    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
                    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
                    renderer.setSize(canvas.clientWidth, canvas.clientHeight);

                    const group = new THREE.Group();
                    scene.add(group);

                    const nodeCount = 40;
                    const nodes = [];
                    const geo = new THREE.SphereGeometry(0.3, 12, 12);
                    const mat = new THREE.MeshBasicMaterial({ color: 0x3b82f6 });

                    for (let i = 0; i < nodeCount; i++) {
                        const node = new THREE.Mesh(geo, mat);
                        node.position.set((Math.random() - 0.5) * 60, (Math.random() - 0.5) * 40, (Math.random() - 0.5) * 20);
                        node.velocity = new THREE.Vector3((Math.random() - 0.5) * 0.05, (Math.random() - 0.5) * 0.05, (Math.random() - 0.5) * 0.05);
                        group.add(node);
                        nodes.push(node);
                    }

                    function animate() {
                        requestAnimationFrame(animate);
                        nodes.forEach(node => {
                            node.position.add(node.velocity);
                            if (Math.abs(node.position.x) > 35) node.velocity.x *= -1;
                            if (Math.abs(node.position.y) > 25) node.velocity.y *= -1;
                            if (Math.abs(node.position.z) > 15) node.velocity.z *= -1;
                        });
                        group.rotation.y += 0.001;
                        group.rotation.x += 0.0005;
                        renderer.render(scene, camera);
                    }

                    const onResize = () => {
                        const parent = canvas.parentElement;
                        renderer.setSize(parent.clientWidth, parent.clientHeight);
                        camera.aspect = parent.clientWidth / parent.clientHeight;
                        camera.updateProjectionMatrix();
                    };
                    window.addEventListener('resize', onResize);
                    animate();
                })();

                (function () {
                    const canvas = document.getElementById('noticeCanvas');
                    if (!canvas) return;

                    const scene = new THREE.Scene();
                    const camera = new THREE.PerspectiveCamera(45, canvas.clientWidth / canvas.clientHeight, 0.1, 1000);
                    camera.position.z = 50;

                    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
                    renderer.setSize(canvas.clientWidth, canvas.clientHeight);

                    const count = 80;
                    const lines = [];
                    const mat = new THREE.LineBasicMaterial({ color: 0xf59e0b, transparent: true, opacity: 0.2 });

                    for (let i = 0; i < count; i++) {
                        const geo = new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(0, 0, 0), new THREE.Vector3(0, Math.random() * 8, 0)]);
                        const line = new THREE.Line(geo, mat);
                        line.position.set((Math.random() - 0.5) * 150, (Math.random() - 0.5) * 100, (Math.random() - 0.5) * 50);
                        scene.add(line);
                        lines.push({ mesh: line, speed: Math.random() * 0.15 + 0.05 });
                    }

                    function animate() {
                        requestAnimationFrame(animate);
                        lines.forEach(l => {
                            l.mesh.position.y -= l.speed;
                            if (l.mesh.position.y < -60) l.mesh.position.y = 60;
                        });
                        renderer.render(scene, camera);
                    }
                    animate();

                    window.addEventListener('resize', () => {
                        const p = canvas.parentElement;
                        renderer.setSize(p.clientWidth, p.clientHeight);
                        camera.aspect = p.clientWidth / p.clientHeight;
                        camera.updateProjectionMatrix();
                    });
                })();

                (function () {
                    const canvas = document.getElementById('programCanvas');
                    if (!canvas) return;

                    const scene = new THREE.Scene();
                    const camera = new THREE.PerspectiveCamera(45, canvas.clientWidth / canvas.clientHeight, 0.1, 1000);
                    camera.position.z = 60;

                    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
                    renderer.setSize(canvas.clientWidth, canvas.clientHeight);

                    const group = new THREE.Group();
                    scene.add(group);

                    const count = 5;
                    const orbs = [];
                    for (let i = 0; i < count; i++) {
                        const geo = new THREE.IcosahedronGeometry(4, 0);
                        const mat = new THREE.MeshBasicMaterial({ color: 0x00b366, wireframe: true, transparent: true, opacity: 0.3 });
                        const orb = new THREE.Mesh(geo, mat);
                        const angle = (i / count) * Math.PI * 2;
                        orb.position.set(Math.cos(angle) * 25, Math.sin(angle) * 25, 0);
                        group.add(orb);
                        orbs.push(orb);
                    }

                    function animate() {
                        requestAnimationFrame(animate);
                        group.rotation.z += 0.005;
                        orbs.forEach(o => o.rotation.y += 0.01);
                        renderer.render(scene, camera);
                    }
                    animate();

                    window.addEventListener('resize', () => {
                        const p = canvas.parentElement;
                        renderer.setSize(p.clientWidth, p.clientHeight);
                        camera.aspect = p.clientWidth / p.clientHeight;
                        camera.updateProjectionMatrix();
                    });
                })();

                // Initialize Bootstrap Carousel manually to force auto-sliding
                const heroCarouselElement = document.querySelector('#mainHeroCarousel');
                if (heroCarouselElement && window.bootstrap) {
                    new window.bootstrap.Carousel(heroCarouselElement, {
                        interval: 5000,
                        ride: 'carousel',
                        pause: 'hover'
                    });
                }
            });
        </script>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
