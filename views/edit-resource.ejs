<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <title>ফাইল এডিট করুন</title>
    <style>
        body { background: #020617; color: white; font-family: sans-serif; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; }
        .card { background: rgba(30, 41, 59, 0.5); backdrop-filter: blur(10px); padding: 30px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1); width: 100%; max-width: 450px; }
        h3 { color: #10b981; margin-top: 0; text-align: center; }
        input, select { width: 100%; padding: 12px; margin: 10px 0; border-radius: 10px; border: 1px solid #334155; background: #0f172a; color: white; box-sizing: border-box; }
        .btn { width: 100%; padding: 12px; border-radius: 10px; border: none; font-weight: bold; cursor: pointer; background: #10b981; color: white; transition: 0.3s; }
        .btn:hover { opacity: 0.8; }
        .back-link { display: block; text-align: center; margin-top: 15px; color: #94a3b8; text-decoration: none; font-size: 14px; }
    </style>
</head>
<body>
    <div class="card">
        <h3>ফাইল তথ্য আপডেট</h3>
        <form action="/admin/update-resource/<%= resource.id %>" method="POST" enctype="multipart/form-data">
            <label>ফাইলের নাম:</label>
            <input type="text" name="title" value="<%= resource.title %>" required>
            
            <label>দৃশ্যমানতা:</label>
            <select name="visibility">
                <option value="পাবলিক" <%= resource.visibility === 'পাবলিক' ? 'selected' : '' %>>পাবলিক</option>
                <option value="কর্মী" <%= resource.visibility === 'কর্মী' ? 'selected' : '' %>>কর্মী</option>
                <option value="সাথী" <%= resource.visibility === 'সাথী' ? 'selected' : '' %>>সাথী</option>
            </select>

            <label>নতুন ফাইল (পরিবর্তন না করতে চাইলে খালি রাখুন):</label>
            <input type="file" name="file">

            <label>বাহ্যিক লিঙ্ক (যদি থাকে):</label>
            <input type="url" name="external_url" value="<%= resource.external_url || '' %>">

            <button type="submit" class="btn">আপডেট নিশ্চিত করুন</button>
            <a href="/admin" class="back-link">ফিরে যান</a>
        </form>
    </div>
</body>
</html>