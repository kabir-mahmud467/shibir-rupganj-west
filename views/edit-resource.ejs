<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('partials/seo') %>

    <title>ফাইল এডিট করুন | রূপগঞ্জ পশ্চিম</title>
    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* edit-resource.ejs specific styles only */
        .edit-resource-card { 
            background: rgba(30, 41, 59, 0.4); 
            backdrop-filter: blur(12px); 
            padding: 30px; 
            border-radius: 20px; 
            border: 1px solid rgba(255,255,255,0.1); 
            width: 100%; 
            max-width: 480px; 
            box-shadow: 0 20px 40px rgba(0,0,0,0.6);
        }

        h3 { 
            color: #10b981; 
            margin-top: 0; 
            text-align: center; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            gap: 12px;
            font-size: 1.5rem;
        }

        label { 
            display: block; 
            margin-top: 15px; 
            color: #94a3b8; 
            font-size: 14px; 
            font-weight: 500;
        }

        input, select { 
            width: 100%; 
            padding: 12px; 
            margin: 8px 0; 
            border-radius: 10px; 
            border: 1px solid #334155; 
            background: #0f172a; 
            color: white; 
            box-sizing: border-box; 
            outline: none;
            transition: 0.3s;
        }

        input:focus, select:focus { 
            border-color: #10b981; 
            box-shadow: 0 0 10px rgba(16, 185, 129, 0.2); 
        }

        .current-info {
            background: rgba(16, 185, 129, 0.1);
            padding: 10px;
            border-radius: 8px;
            font-size: 12px;
            color: #10b981;
            margin-bottom: 5px;
            border: 1px dashed rgba(16, 185, 129, 0.3);
        }

        .btn { 
            width: 100%; 
            padding: 14px; 
            border-radius: 10px; 
            border: none; 
            font-weight: bold; 
            cursor: pointer; 
            background: linear-gradient(45deg, #10b981, #059669); 
            color: white; 
            font-size: 16px;
            margin-top: 20px;
            transition: 0.3s;
        }

        .btn:hover { 
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(16, 185, 129, 0.4);
        }

        .back-link { 
            display: block; 
            text-align: center; 
            margin-top: 15px; 
            color: #94a3b8; 
            text-decoration: none; 
            font-size: 14px; 
            transition: 0.3s;
        }
        
        .back-link:hover { color: white; }

        input[type="file"] {
            padding: 8px;
            font-size: 13px;
        }
    </style>
</head>
<body>
    <%- include('partials/main-nav') %>
    <div style="padding: 20px; display: flex; justify-content: center;">
        <div class="edit-resource-card">
            <h3><i class="fas fa-file-pen"></i> ফাইল তথ্য আপডেট</h3>
        
        <form action="/admin/update-resource/<%= resource.id %>" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            
            <label>ফাইলের নাম বা শিরোনাম:</label>
            <input type="text" name="title" value="<%= resource.title %>" placeholder="যেমন: সিলেবাস ২০২৪" required>
            
            <label>দৃশ্যমানতা (Visibility):</label>
            <select name="visibility">
                <option value="পাবলিক" <%= resource.visibility === 'পাবলিক' ? 'selected' : '' %>>পাবলিক (সবাই দেখবে)</option>
                <option value="কর্মী" <%= resource.visibility === 'কর্মী' ? 'selected' : '' %>>কর্মী (শুধু কর্মীরা)</option>
                <option value="সাথী" <%= resource.visibility === 'সাথী' ? 'selected' : '' %>>সাথী (শুধু সাথীরা)</option>
            </select>

            <label>বর্তমান লিঙ্ক:</label>
            <div class="current-info">
                <i class="fas fa-link"></i> 
                <% if (resource.url) { %>
                    <%= resource.url %>
                <% } else { %>
                    কোনো লিঙ্ক নেই
                <% } %>
            </div>

            <label>বইয়ের লিঙ্ক (Google Drive/URL):</label>
            <input type=\"url\" name=\"url\" value=\"<%= resource.url || '' %>\" placeholder=\"https://drive.google.com/...\" required>

            <label>বইয়ের ছবির URL (Cloudinary/অন্যান্য):</label>
            <input type=\"url\" name=\"imageUrl\" value=\"<%= resource.imageUrl || '' %>\" placeholder=\"https://example.com/book-image.jpg\">

            <button type="submit" class="btn">আপডেট নিশ্চিত করুন</button>
            <a href="/admin" class="back-link">
                <i class="fas fa-arrow-left"></i> পরিবর্তন ছাড়াই ফিরে যান
            </a>
        </form>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
