<meta property="og:title" content="বাংলাদেশ ইসলামী ছাত্রশিবির - রূপগঞ্জ পশ্চিম থানা">
<meta property="og:description" content="সত্য ও সুন্দরের পথে কাফেলা। রূপগঞ্জ পশ্চিম থানা শাখার সব তথ্য, কর্মসূচি ও লাইব্রেরি।">
<meta property="og:image" content="https://www.dushibir.org/storage/setting_images/wKFhZtq3w8jQDZT9wLfeJJXeGW09yJss7WACq03k.png">
<meta property="og:type" content="website">
<meta name="author" content="বাংলাদেশ ইসলামী ছাত্রশিবির - রূপগঞ্জ পশ্চিম">
<script>
  (function () {
    let swRegistration = null;
    let deferredInstallPrompt = null;
    const NOTICE_POLL_INTERVAL_MS = 60000;
    const NOTICE_LAST_SEEN_KEY = "rw_last_seen_notice_id";

    const isStandalone = function () {
      return (
        window.matchMedia("(display-mode: standalone)").matches ||
        window.navigator.standalone === true
      );
    };

    const setInstallHint = function (trigger, message) {
      const targetSelector = trigger && trigger.dataset ? trigger.dataset.installHintTarget : "";
      if (!targetSelector) return;
      const hintElement = document.querySelector(targetSelector);
      if (hintElement) hintElement.textContent = message;
    };

    const setInstallTriggerVisibility = function (trigger, visible) {
      if (!trigger) return;
      trigger.style.display = visible ? "" : "none";
    };

    const notifyInstallStatus = async function (title, body) {
      if (!("Notification" in window)) return;
      if (Notification.permission !== "granted") return;

      const options = {
        body: body,
        icon: "/icons/icon-192.png",
        badge: "/icons/icon-192.png",
        tag: "rw-pwa-install"
      };

      try {
        if (swRegistration) {
          await swRegistration.showNotification(title, options);
          return;
        }
      } catch (error) {
        // fall through to page notification
      }

      try {
        new Notification(title, options);
      } catch (error) {
        // no-op
      }
    };

    const notifyIfGranted = async function (title, body, tag, url) {
      if (!("Notification" in window)) return;
      if (Notification.permission !== "granted") return;

      const options = {
        body: body,
        icon: "/icons/icon-192.png",
        badge: "/icons/icon-192.png",
        tag: tag || "rw-notice",
        data: { url: url || "/" }
      };

      try {
        if (swRegistration) {
          await swRegistration.showNotification(title, options);
          return;
        }
      } catch (error) {
        // fall through to page notification
      }

      try {
        new Notification(title, options);
      } catch (error) {
        // no-op
      }
    };

    const showInAppNotice = function (title, body, url) {
      let host = document.getElementById("rw-in-app-notice-host");
      if (!host) {
        host = document.createElement("div");
        host.id = "rw-in-app-notice-host";
        host.style.position = "fixed";
        host.style.right = "16px";
        host.style.bottom = "16px";
        host.style.zIndex = "9999";
        host.style.display = "flex";
        host.style.flexDirection = "column";
        host.style.gap = "10px";
        host.style.maxWidth = "320px";
        document.body.appendChild(host);
      }

      const card = document.createElement("div");
      card.style.background = "rgba(7, 53, 33, 0.95)";
      card.style.color = "#ffffff";
      card.style.border = "1px solid rgba(255,255,255,0.2)";
      card.style.borderRadius = "12px";
      card.style.padding = "12px 14px";
      card.style.boxShadow = "0 10px 25px rgba(0,0,0,0.35)";
      card.style.fontFamily = "Hind Siliguri, sans-serif";

      const heading = document.createElement("div");
      heading.textContent = title;
      heading.style.fontWeight = "700";
      heading.style.marginBottom = "6px";

      const message = document.createElement("div");
      message.textContent = body || "New notice available.";
      message.style.fontSize = "0.92rem";
      message.style.opacity = "0.9";
      message.style.marginBottom = "10px";

      const actions = document.createElement("div");
      actions.style.display = "flex";
      actions.style.gap = "8px";

      const openBtn = document.createElement("a");
      openBtn.href = url || "/notices";
      openBtn.textContent = "Open";
      openBtn.style.textDecoration = "none";
      openBtn.style.fontSize = "0.85rem";
      openBtn.style.fontWeight = "700";
      openBtn.style.background = "#ffd54a";
      openBtn.style.color = "#1f2937";
      openBtn.style.padding = "6px 10px";
      openBtn.style.borderRadius = "8px";

      const closeBtn = document.createElement("button");
      closeBtn.type = "button";
      closeBtn.textContent = "Dismiss";
      closeBtn.style.fontSize = "0.85rem";
      closeBtn.style.padding = "6px 10px";
      closeBtn.style.borderRadius = "8px";
      closeBtn.style.border = "1px solid rgba(255,255,255,0.35)";
      closeBtn.style.background = "transparent";
      closeBtn.style.color = "#ffffff";
      closeBtn.style.cursor = "pointer";
      closeBtn.addEventListener("click", function () {
        if (card.parentNode) card.parentNode.removeChild(card);
      });

      actions.appendChild(openBtn);
      actions.appendChild(closeBtn);
      card.appendChild(heading);
      card.appendChild(message);
      card.appendChild(actions);
      host.appendChild(card);

      window.setTimeout(function () {
        if (card.parentNode) card.parentNode.removeChild(card);
      }, 15000);
    };

    const buildNoticeBody = function (notice) {
      if (!notice) return "";
      const text = notice.content || "";
      if (text.length <= 90) return text;
      return text.slice(0, 90) + "...";
    };

    const checkForNewNotice = async function () {
      try {
        const response = await fetch("/api/notices/latest", {
          method: "GET",
          credentials: "same-origin",
          cache: "no-store"
        });
        if (!response.ok) return;

        const payload = await response.json();
        if (!payload || !payload.ok || !payload.notice) return;

        const latestNotice = payload.notice;
        const savedNoticeId = localStorage.getItem(NOTICE_LAST_SEEN_KEY);

        if (!savedNoticeId) {
          localStorage.setItem(NOTICE_LAST_SEEN_KEY, latestNotice.id);
          return;
        }

        if (savedNoticeId === latestNotice.id) return;

        localStorage.setItem(NOTICE_LAST_SEEN_KEY, latestNotice.id);
        if ("Notification" in window && Notification.permission === "granted") {
          await notifyIfGranted(
            "নতুন নোটিশ এসেছে",
            buildNoticeBody(latestNotice),
            "rw-notice-" + latestNotice.id,
            latestNotice.url
          );
        } else {
          showInAppNotice(
            "নতুন নোটিশ এসেছে",
            buildNoticeBody(latestNotice),
            latestNotice.url
          );
        }
      } catch (error) {
        // silent fail for polling
      }
    };

    if ("serviceWorker" in navigator) {
      window.addEventListener("load", function () {
        navigator.serviceWorker
          .register("/sw.js")
          .then(function (registration) {
            swRegistration = registration;
          })
          .catch(function (error) {
            console.error("Service worker registration failed:", error);
          });
      });
    }

    window.addEventListener("beforeinstallprompt", function (event) {
      event.preventDefault();
      deferredInstallPrompt = event;
      document.querySelectorAll(".pwa-install-trigger").forEach(function (trigger) {
        setInstallHint(trigger, "অ্যাপ ইনস্টল করুন");
      });
      notifyInstallStatus("অ্যাপ প্রস্তুত", "অ্যাপ ইনস্টল করার জন্য প্রস্তুত।");
    });

    window.addEventListener("appinstalled", function () {
      deferredInstallPrompt = null;
      document.querySelectorAll(".pwa-install-trigger").forEach(function (trigger) {
        setInstallHint(trigger, "অ্যাপ সফলভাবে ইনস্টল হয়েছে");
        setInstallTriggerVisibility(trigger, false);
      });
      alert("অ্যাপ সফলভাবে ইনস্টল হয়েছে।");
      notifyInstallStatus("ইনস্টল সম্পন্ন", "অ্যাপ সফলভাবে ইনস্টল হয়েছে।");
      window.setTimeout(function () {
        window.location.href = "/";
      }, 700);
    });

    document.addEventListener("DOMContentLoaded", function () {
      const installTriggers = document.querySelectorAll(".pwa-install-trigger");

      checkForNewNotice();
      window.setInterval(checkForNewNotice, NOTICE_POLL_INTERVAL_MS);

      if (!installTriggers.length) return;

      installTriggers.forEach(function (trigger) {
        if (isStandalone()) {
          setInstallTriggerVisibility(trigger, false);
          return;
        }

        trigger.addEventListener("click", async function (event) {
          event.preventDefault();

          if (isStandalone()) {
            setInstallTriggerVisibility(trigger, false);
            return;
          }

          if (!deferredInstallPrompt) {
            setInstallHint(trigger, "অ্যাপ ইনস্টল করুন");
            alert("এই ডিভাইসে ইনস্টল প্রম্পট পাওয়া যাচ্ছে না।");
            await notifyInstallStatus("ইনস্টল পাওয়া যাচ্ছে না", "এই ব্রাউজারে ইনস্টল প্রম্পট পাওয়া যাচ্ছে না।");
            return;
          }

          setInstallHint(trigger, "অ্যাপ ইনস্টল হচ্ছে...");
          alert("অ্যাপ ইনস্টল হচ্ছে, কিছুক্ষণ অপেক্ষা করুন।");
          deferredInstallPrompt.prompt();
          const choiceResult = await deferredInstallPrompt.userChoice;
          const outcome = choiceResult && choiceResult.outcome ? choiceResult.outcome : "dismissed";

          if (outcome === "accepted") {
            setInstallHint(trigger, "ইনস্টল অনুরোধ গৃহীত হয়েছে");
            await notifyInstallStatus("ইনস্টল শুরু হয়েছে", "আপনার ইনস্টল অনুরোধ গৃহীত হয়েছে।");
            deferredInstallPrompt = null;
          } else {
            setInstallHint(trigger, "অ্যাপ ইনস্টল করুন");
            await notifyInstallStatus("ইনস্টল বাতিল", "আপনি অ্যাপ ইনস্টল বাতিল করেছেন।");
            alert("ইনস্টল বাতিল হয়েছে। আবার চেষ্টা করতে পেজ রিফ্রেশ হচ্ছে।");
            window.setTimeout(function () {
              window.location.reload();
            }, 400);
            return;
          }
        });
      });
    });
  })();
</script>
