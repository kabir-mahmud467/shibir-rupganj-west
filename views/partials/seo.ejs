<meta name="keywords" content="rupganj west shibir, rupganj west, রূপগঞ্জ পশ্চিম, বাংলাদেশ ইসলামী ছাত্রশিবির, ছাত্রশিবির রূপগঞ্জ পশ্চিম, রূপগঞ্জ পশ্চিম থানা, Rupganj West Thana, Shibir Rupganj West">
<meta property="og:title" content="বাংলাদেশ ইসলামী ছাত্রশিবির - রূপগঞ্জ পশ্চিম থানা">
<meta property="og:description" content="সত্য ও সুন্দরের পথে কাফেলা। রূপগঞ্জ পশ্চিম থানা শাখার সব তথ্য, কর্মসূচি ও লাইব্রেরি।">
<meta property="og:image" content="https://www.dushibir.org/storage/setting_images/wKFhZtq3w8jQDZT9wLfeJJXeGW09yJss7WACq03k.png">
<meta property="og:type" content="website">
<meta name="author" content="বাংলাদেশ ইসলামী ছাত্রশিবির - রূপগঞ্জ পশ্চিম">
<script>
  (function () {
    let swRegistration = null;
    let deferredInstallPrompt = null;
    const NOTICE_POLL_INTERVAL_MS = 60000;
    const NOTICE_LAST_SEEN_KEY = "rw_last_seen_notice_id";
    const NOTICE_PERMISSION_ASKED_KEY = "rw_notice_permission_asked";
    const NOTICE_SOUND_ENABLED_KEY = "rw_notice_sound_enabled";
    let noticeAudioContext = null;
    let noticeAudioUnlocked = false;

    const isStandalone = function () {
      return (
        window.matchMedia("(display-mode: standalone)").matches ||
        window.navigator.standalone === true
      );
    };

    const setInstallHint = function (trigger, message) {
      const targetSelector = trigger && trigger.dataset ? trigger.dataset.installHintTarget : "";
      if (!targetSelector) return;
      const hintElement = document.querySelector(targetSelector);
      if (hintElement) hintElement.textContent = message;
    };

    const setInstallTriggerVisibility = function (trigger, visible) {
      if (!trigger) return;
      trigger.style.display = visible ? "" : "none";
    };

    const notifyInstallStatus = async function (title, body) {
      if (!("Notification" in window)) return;
      if (Notification.permission !== "granted") return;

      const options = {
        body: body,
        icon: "/icons/icon-192.png",
        badge: "/icons/icon-192.png",
        tag: "rw-pwa-install"
      };

      try {
        if (swRegistration) {
          await swRegistration.showNotification(title, options);
          return;
        }
      } catch (error) {
        // fall through to page notification
      }

      try {
        new Notification(title, options);
      } catch (error) {
        // no-op
      }
    };

    const notifyIfGranted = async function (title, body, tag, url) {
      if (!("Notification" in window)) return;
      if (Notification.permission !== "granted") return;

      const options = {
        body: body,
        icon: "/icons/icon-192.png",
        badge: "/icons/icon-192.png",
        tag: tag || "rw-notice",
        data: { url: url || "/" },
        renotify: true,
        vibrate: [130, 60, 130],
        requireInteraction: false,
        actions: [
          { action: "open_notice", title: "নোটিশ দেখুন" },
          { action: "dismiss", title: "বন্ধ করুন" }
        ]
      };

      try {
        if (swRegistration) {
          await swRegistration.showNotification(title, options);
          return;
        }
      } catch (error) {
        // fall through to page notification
      }

      try {
        new Notification(title, options);
      } catch (error) {
        // no-op
      }
    };

    const shouldPlayNoticeSound = function () {
      const saved = localStorage.getItem(NOTICE_SOUND_ENABLED_KEY);
      return saved !== "off";
    };

    const unlockNoticeAudio = function (triggerEvent) {
      if (triggerEvent && !triggerEvent.isTrusted) return;
      if (navigator.userActivation && !navigator.userActivation.isActive) return;
      const AudioContextClass = window.AudioContext || window.webkitAudioContext;
      if (!AudioContextClass) return;
      if (!noticeAudioContext) {
        noticeAudioContext = new AudioContextClass();
      }
      if (noticeAudioContext.state === "suspended") {
        noticeAudioContext.resume().catch(function () {
          // no-op
        });
      }
      noticeAudioUnlocked = noticeAudioContext.state === "running";
    };

    const playNoticeSound = function () {
      if (!shouldPlayNoticeSound()) return;
      if (!noticeAudioUnlocked || !noticeAudioContext) return;
      const now = noticeAudioContext.currentTime;
      const notes = [698.46, 783.99, 932.33];

      notes.forEach(function (frequency, index) {
        const osc = noticeAudioContext.createOscillator();
        const gain = noticeAudioContext.createGain();
        osc.type = "sine";
        osc.frequency.value = frequency;

        const start = now + index * 0.12;
        const end = start + 0.18;
        gain.gain.setValueAtTime(0.0001, start);
        gain.gain.exponentialRampToValueAtTime(0.09, start + 0.03);
        gain.gain.exponentialRampToValueAtTime(0.0001, end);

        osc.connect(gain);
        gain.connect(noticeAudioContext.destination);
        osc.start(start);
        osc.stop(end);
      });
    };

    const requestNotificationPermissionIfNeeded = function () {
      if (!("Notification" in window)) return;
      if (Notification.permission !== "default") return;
      if (localStorage.getItem(NOTICE_PERMISSION_ASKED_KEY) === "yes") return;
      localStorage.setItem(NOTICE_PERMISSION_ASKED_KEY, "yes");
      Notification.requestPermission().then(function (permission) {
        if (permission === "granted") {
          showInAppNotice(
            "নোটিফিকেশন চালু হয়েছে",
            "নতুন নোটিশ এখন মোবাইল নোটিফিকেশন বারেও দেখাবে।",
            "/notices"
          );
        }
      }).catch(function () {
        // no-op
      });
    };

    const showInAppNotice = function (title, body, url) {
      let host = document.getElementById("rw-in-app-notice-host");
      if (!host) {
        host = document.createElement("div");
        host.id = "rw-in-app-notice-host";
        host.style.position = "fixed";
        host.style.right = "16px";
        host.style.bottom = "16px";
        host.style.zIndex = "9999";
        host.style.display = "flex";
        host.style.flexDirection = "column";
        host.style.gap = "10px";
        host.style.maxWidth = "320px";
        document.body.appendChild(host);
      }

      const card = document.createElement("div");
      card.style.background = "rgba(7, 53, 33, 0.95)";
      card.style.color = "#ffffff";
      card.style.border = "1px solid rgba(255,255,255,0.2)";
      card.style.borderRadius = "12px";
      card.style.padding = "12px 14px";
      card.style.boxShadow = "0 10px 25px rgba(0,0,0,0.35)";
      card.style.fontFamily = "Hind Siliguri, sans-serif";

      const heading = document.createElement("div");
      heading.textContent = title;
      heading.style.fontWeight = "700";
      heading.style.marginBottom = "6px";

      const message = document.createElement("div");
      message.textContent = body || "New notice available.";
      message.style.fontSize = "0.92rem";
      message.style.opacity = "0.9";
      message.style.marginBottom = "10px";

      const actions = document.createElement("div");
      actions.style.display = "flex";
      actions.style.gap = "8px";

      const openBtn = document.createElement("a");
      openBtn.href = url || "/notices";
      openBtn.textContent = "Open";
      openBtn.style.textDecoration = "none";
      openBtn.style.fontSize = "0.85rem";
      openBtn.style.fontWeight = "700";
      openBtn.style.background = "#ffd54a";
      openBtn.style.color = "#1f2937";
      openBtn.style.padding = "6px 10px";
      openBtn.style.borderRadius = "8px";

      const closeBtn = document.createElement("button");
      closeBtn.type = "button";
      closeBtn.textContent = "Dismiss";
      closeBtn.style.fontSize = "0.85rem";
      closeBtn.style.padding = "6px 10px";
      closeBtn.style.borderRadius = "8px";
      closeBtn.style.border = "1px solid rgba(255,255,255,0.35)";
      closeBtn.style.background = "transparent";
      closeBtn.style.color = "#ffffff";
      closeBtn.style.cursor = "pointer";
      closeBtn.addEventListener("click", function () {
        if (card.parentNode) card.parentNode.removeChild(card);
      });

      actions.appendChild(openBtn);
      actions.appendChild(closeBtn);
      card.appendChild(heading);
      card.appendChild(message);
      card.appendChild(actions);
      host.appendChild(card);

      window.setTimeout(function () {
        if (card.parentNode) card.parentNode.removeChild(card);
      }, 15000);
    };

    const ensureInstallPromptStyles = function () {
      if (document.getElementById("rw-install-prompt-styles")) return;
      const style = document.createElement("style");
      style.id = "rw-install-prompt-styles";
      style.textContent = `
        #rw-install-prompt-host{
          position:fixed;inset:0;pointer-events:none;z-index:10020;
          display:flex;align-items:flex-end;justify-content:center;padding:20px 14px;
        }
        .rw-install-prompt-card{
          width:min(420px,100%);pointer-events:auto;position:relative;
          border-radius:16px;border:1px solid rgba(255,255,255,.22);
          box-shadow:0 18px 50px rgba(0,0,0,.28);padding:16px 44px 16px 16px;
          color:#ffffff;font-family:"Hind Siliguri",sans-serif;line-height:1.45;
          transform:translateY(16px) scale(.97);opacity:0;
          transition:transform .28s ease, opacity .28s ease;
          backdrop-filter: blur(7px);
        }
        .rw-install-prompt-card.show{transform:translateY(0) scale(1);opacity:1}
        .rw-install-prompt-card.rw-tone-success{background:linear-gradient(135deg,#075b33,#0b8e4f)}
        .rw-install-prompt-card.rw-tone-info{background:linear-gradient(135deg,#1b4965,#2f6f8f)}
        .rw-install-prompt-card.rw-tone-warning{background:linear-gradient(135deg,#7a4c00,#ad6d06)}
        .rw-install-prompt-title{font-size:1rem;font-weight:700;margin:0 0 4px}
        .rw-install-prompt-body{font-size:.92rem;opacity:.92;margin:0}
        .rw-install-prompt-close{
          position:absolute;top:10px;right:10px;background:rgba(255,255,255,.14);
          border:1px solid rgba(255,255,255,.25);color:#fff;width:28px;height:28px;
          border-radius:999px;cursor:pointer;font-size:16px;line-height:1;
        }
        .rw-install-prompt-close:hover{background:rgba(255,255,255,.22)}
      `;
      document.head.appendChild(style);
    };

    const showInstallPromptBox = function (title, body, tone) {
      ensureInstallPromptStyles();
      let host = document.getElementById("rw-install-prompt-host");
      if (!host) {
        host = document.createElement("div");
        host.id = "rw-install-prompt-host";
        document.body.appendChild(host);
      }

      const card = document.createElement("div");
      card.className = "rw-install-prompt-card rw-tone-" + (tone || "info");

      const heading = document.createElement("p");
      heading.className = "rw-install-prompt-title";
      heading.textContent = title;

      const message = document.createElement("p");
      message.className = "rw-install-prompt-body";
      message.textContent = body;

      const closeButton = document.createElement("button");
      closeButton.type = "button";
      closeButton.className = "rw-install-prompt-close";
      closeButton.textContent = "×";

      const dismiss = function () {
        card.classList.remove("show");
        window.setTimeout(function () {
          if (card.parentNode) card.parentNode.removeChild(card);
        }, 280);
      };

      closeButton.addEventListener("click", dismiss);

      card.appendChild(heading);
      card.appendChild(message);
      card.appendChild(closeButton);
      host.appendChild(card);

      window.requestAnimationFrame(function () {
        card.classList.add("show");
      });

      window.setTimeout(dismiss, 3800);
    };
    const buildNoticeBody = function (notice) {
      if (!notice) return "";
      const text = notice.content || "";
      if (text.length <= 90) return text;
      return text.slice(0, 90) + "...";
    };

    const checkForNewNotice = async function () {
      try {
        const response = await fetch("/api/notices/latest", {
          method: "GET",
          credentials: "same-origin",
          cache: "no-store"
        });
        if (!response.ok) return;

        const payload = await response.json();
        if (!payload || !payload.ok || !payload.notice) return;

        const latestNotice = payload.notice;
        const savedNoticeId = localStorage.getItem(NOTICE_LAST_SEEN_KEY);

        if (!savedNoticeId) {
          localStorage.setItem(NOTICE_LAST_SEEN_KEY, latestNotice.id);
          return;
        }

        if (savedNoticeId === latestNotice.id) return;

        localStorage.setItem(NOTICE_LAST_SEEN_KEY, latestNotice.id);
        showInAppNotice(
          "নতুন নোটিশ এসেছে",
          buildNoticeBody(latestNotice),
          latestNotice.url
        );
        playNoticeSound();

        if ("Notification" in window && Notification.permission === "granted") {
          await notifyIfGranted(
            "নতুন নোটিশ এসেছে",
            buildNoticeBody(latestNotice),
            "rw-notice-" + latestNotice.id,
            latestNotice.url
          );
        }
      } catch (error) {
        // silent fail for polling
      }
    };

    if ("serviceWorker" in navigator) {
      window.addEventListener("load", function () {
        navigator.serviceWorker
          .register("/sw.js")
          .then(function (registration) {
            swRegistration = registration;
          })
          .catch(function (error) {
            console.error("Service worker registration failed:", error);
          });
      });
    }

    window.addEventListener("beforeinstallprompt", function (event) {
      event.preventDefault();
      deferredInstallPrompt = event;
      document.querySelectorAll(".pwa-install-trigger").forEach(function (trigger) {
        setInstallHint(trigger, "অ্যাপ ইনস্টল করুন");
      });
      showInstallPromptBox("অ্যাপ প্রস্তুত", "অ্যাপ ইনস্টল করার জন্য প্রস্তুত।", "info");
      notifyInstallStatus("অ্যাপ প্রস্তুত", "অ্যাপ ইনস্টল করার জন্য প্রস্তুত।");
    });

    window.addEventListener("appinstalled", function () {
      deferredInstallPrompt = null;
      document.querySelectorAll(".pwa-install-trigger").forEach(function (trigger) {
        setInstallHint(trigger, "অ্যাপ সফলভাবে ইনস্টল হয়েছে");
        setInstallTriggerVisibility(trigger, false);
      });
      showInstallPromptBox("ইনস্টল সম্পন্ন", "আপনার ডিভাইসে অ্যাপটি ইন্সটল করা আছে", "success");
      notifyInstallStatus("ইনস্টল সম্পন্ন", "অ্যাপ সফলভাবে ইনস্টল হয়েছে।");
      window.setTimeout(function () {
        window.location.href = "/";
      }, 700);
    });

    document.addEventListener("DOMContentLoaded", function () {
      const installTriggers = document.querySelectorAll(".pwa-install-trigger");
      const setupNoticeInteraction = function (event) {
        if (event && !event.isTrusted) return;
        unlockNoticeAudio(event);
        requestNotificationPermissionIfNeeded();
      };
      document.addEventListener("pointerdown", setupNoticeInteraction, { once: true, passive: true, capture: true });
      document.addEventListener("keydown", setupNoticeInteraction, { once: true, capture: true });

      checkForNewNotice();
      window.setInterval(checkForNewNotice, NOTICE_POLL_INTERVAL_MS);

      if (!installTriggers.length) return;

      installTriggers.forEach(function (trigger) {
        if (isStandalone()) {
          setInstallTriggerVisibility(trigger, false);
          return;
        }

        trigger.addEventListener("click", async function (event) {
          event.preventDefault();

          if (isStandalone()) {
            setInstallTriggerVisibility(trigger, false);
            return;
          }

          if (!deferredInstallPrompt) {
            setInstallHint(trigger, "আপনার ডিভাইসে অ্যাপটি ইন্সটল করা আছে");
            showInstallPromptBox("ইনস্টল স্ট্যাটাস", "আপনার ডিভাইসে অ্যাপটি ইন্সটল করা আছে", "success");
            await notifyInstallStatus("ইনস্টল সম্পন্ন", "আপনার ডিভাইসে অ্যাপটি ইন্সটল করা আছে");
            return;
          }

          setInstallHint(trigger, "অ্যাপ ইনস্টল হচ্ছে...");
          showInstallPromptBox("ইনস্টল চলছে", "অ্যাপ ইন্সটল হচ্ছে, কিছুক্ষণ অপেক্ষা করুন।", "info");
          deferredInstallPrompt.prompt();
          const choiceResult = await deferredInstallPrompt.userChoice;
          const outcome = choiceResult && choiceResult.outcome ? choiceResult.outcome : "dismissed";

          if (outcome === "accepted") {
            setInstallHint(trigger, "ইনস্টল অনুরোধ গৃহীত হয়েছে");
            showInstallPromptBox("ইনস্টল শুরু হয়েছে", "আপনার ইনস্টল অনুরোধ গৃহীত হয়েছে।", "success");
            await notifyInstallStatus("ইনস্টল শুরু হয়েছে", "আপনার ইনস্টল অনুরোধ গৃহীত হয়েছে।");
            deferredInstallPrompt = null;
          } else {
            setInstallHint(trigger, "অ্যাপ ইনস্টল করুন");
            await notifyInstallStatus("ইনস্টল বাতিল", "আপনি অ্যাপ ইনস্টল বাতিল করেছেন।");
            showInstallPromptBox("ইনস্টল বাতিল", "ইন্সটল বাতিল হয়েছে। আবার চেষ্টা করতে পেজ রিফ্রেশ হচ্ছে।", "warning");
            window.setTimeout(function () {
              window.location.reload();
            }, 400);
            return;
          }
        });
      });
    });
  })();
</script>

<style>
  .pw-toggle-btn {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: transparent;
    border: 0;
    padding: 6px;
    line-height: 1;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.75);
  }
  .pw-toggle-btn:hover { color: rgba(255, 255, 255, 0.95); }
  .pw-toggle-btn:focus { outline: 2px solid rgba(0, 210, 255, 0.35); outline-offset: 2px; border-radius: 8px; }
</style>

<script>
  (function () {
    const disableAutofill = function () {
      document.querySelectorAll("form").forEach(function (form) {
        form.setAttribute("autocomplete", "off");
      });

      const skipTypes = new Set(["hidden", "submit", "button", "reset", "file", "image", "checkbox", "radio", "range", "color"]);
      document.querySelectorAll("input, textarea").forEach(function (el) {
        if (el.tagName === "INPUT") {
          const type = String(el.getAttribute("type") || "text").toLowerCase();
          if (skipTypes.has(type)) return;
        }

        el.setAttribute("autocomplete", "off");
        el.setAttribute("autocapitalize", "off");
        el.setAttribute("autocorrect", "off");
        el.setAttribute("spellcheck", "false");
      });
    };

    const addPasswordToggles = function () {
      document.querySelectorAll('input[type="password"]').forEach(function (input) {
        if (input.dataset && input.dataset.pwToggleApplied === "1") return;
        let container = input.parentElement;
        if (!container) return;

        const siblingsControlCount = container.querySelectorAll("input, textarea, select").length;
        if (siblingsControlCount > 1) {
          const wrap = document.createElement("div");
          wrap.style.position = "relative";
          wrap.style.flex = input.style.flex || "1";
          wrap.style.minWidth = "0";
          container.insertBefore(wrap, input);
          wrap.appendChild(input);
          input.style.width = "100%";
          container = wrap;
        }

        try {
          const style = window.getComputedStyle(container);
          if (style && style.position === "static") {
            container.style.position = "relative";
          }
        } catch (e) {
          // no-op
        }

        if (container.querySelector(".pw-toggle-btn")) return;

        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "pw-toggle-btn";
        btn.setAttribute("aria-label", "পাসওয়ার্ড দেখান/লুকান");
        btn.setAttribute("aria-pressed", "false");
        btn.textContent = "👁";

        btn.addEventListener("click", function () {
          const isPassword = input.getAttribute("type") === "password";
          input.setAttribute("type", isPassword ? "text" : "password");
          btn.setAttribute("aria-pressed", isPassword ? "true" : "false");
          btn.textContent = isPassword ? "🙈" : "👁";
        });

        const currentPaddingRight = parseFloat((window.getComputedStyle(input).paddingRight || "0").replace("px", "")) || 0;
        if (currentPaddingRight < 42) input.style.paddingRight = "42px";

        container.appendChild(btn);
        if (input.dataset) input.dataset.pwToggleApplied = "1";
      });
    };

    document.addEventListener("DOMContentLoaded", function () {
      disableAutofill();
      addPasswordToggles();
    });
  })();
</script>



