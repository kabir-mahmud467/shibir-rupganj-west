<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <%- include('partials/seo') %>

    <title>অনলাইন সমর্থক ফরম | বাংলাদেশ ইসলামী ছাত্রশিবির</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    
    <style>
        /* form.ejs specific styles only */
        .form-container {
            max-width: 700px;
            margin: auto;
            background: var(--glass-white);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 25px;
            padding: 40px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        }

        .form-header {
            text-align: center;
            margin-bottom: 40px;
        }

        .form-header img { height: 60px; margin-bottom: 15px; }

        .form-label {
            color: #ccc;
            font-weight: 500;
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

        .form-control, .form-select {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--glass-border);
            color: white;
            border-radius: 10px;
            padding: 12px 15px;
            transition: 0.3s;
        }

        .form-control:focus, .form-select:focus {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--primary-green);
            box-shadow: 0 0 15px rgba(0, 104, 55, 0.3);
            color: white;
        }

        .form-control::placeholder { color: #777; }

        .btn-submit {
            background: linear-gradient(135deg, var(--primary-green), #00a859);
            border: none;
            color: white;
            font-weight: 700;
            padding: 15px;
            border-radius: 12px;
            width: 100%;
            margin-top: 20px;
            transition: 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 104, 55, 0.4);
            color: var(--accent-yellow);
        }

        .section-title {
            color: var(--accent-yellow);
            font-size: 1.1rem;
            font-weight: 600;
            margin: 25px 0 15px;
            display: flex;
            align-items: center;
        }
        .section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--glass-border);
            margin-left: 15px;
        }

        .objectives-box {
            background: rgba(255, 183, 0, 0.15);
            border: 2px solid #ffb700;
            border-radius: 15px;
            padding: 20px;
            margin: 25px 0;
            color: #ffd740;
            font-weight: 600;
            font-size: 1rem;
            line-height: 1.8;
            letter-spacing: 0.5px;
        }

        .objectives-box strong {
            color: #ffeb3b;
            font-size: 1.1rem;
        }

        @media (max-width: 576px) {
            .form-container { padding: 25px; margin: 15px; }
            .hero-title { font-size: 1.5rem; }
        }
    </style>
</head>
<body>
    <%- include('partials/main-nav') %>
    <div class="container">
        <div class="form-container">
            <div class="form-header">
                <a href="/"><img src="https://www.dushibir.org/storage/setting_images/wKFhZtq3w8jQDZT9wLfeJJXeGW09yJss7WACq03k.png" alt="Logo"></a>
                <h3 class="fw-bold text-white">সমর্থক ফরম</h3>
               
            </div>

            <form action="/submit-form" method="POST">
                <div class="section-title"><i class="fas fa-user-circle me-2"></i> ব্যক্তিগত তথ্য</div>
                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label">পুরো নাম</label>
                        <input type="text" name="name" class="form-control" placeholder="আপনার নাম লিখুন" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">মোবাইল নাম্বার</label>
                        <input type="tel" name="phone" class="form-control" placeholder="01XXXXXXXXX" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">ইমেইল (ঐচ্ছিক)</label>
                        <input type="email" name="email" class="form-control" placeholder="example@mail.com">
                    </div>
                </div>

                <div class="section-title"><i class="fas fa-school me-2"></i> শিক্ষা তথ্য</div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">শিক্ষা প্রতিষ্ঠানের নাম</label>
                        <input type="text" name="institution" class="form-control" placeholder="স্কুল/কলেজ/মাদ্রাসার নাম" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">শ্রেণী / বর্ষ</label>
                        <input type="text" name="class_year" class="form-control" placeholder="উদা: দশম শ্রেণি / অনার্স ১ম বর্ষ">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">রোল / বিভাগ</label>
                        <input type="text" name="roll" class="form-control" placeholder="উদা: বিজ্ঞান / রোল-১০">
                    </div>
                </div>

                <div class="section-title"><i class="fas fa-layer-group me-2"></i> শাখা তথ্য</div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">ওয়ার্ডের নাম</label>
                        <input type="text" name="ward" class="form-control" placeholder="ওয়ার্ডের নাম">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">উপশাখার নাম</label>
                        <input type="text" name="branch" class="form-control" placeholder="উপশাখার নাম">
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">অভিভাবকের / ব্যক্তিগত ফোন নম্বর</label>
                        <input type="tel" name="guardian_phone" class="form-control" placeholder="অভিভাবকের / ব্যক্তিগত ফোন নম্বর">
                    </div>
                </div>
                <div class="section-title"><i class="fas fa-map-marker-alt me-2"></i> ঠিকানা</div>
                <div class="mb-3">
                    <label class="form-label">বর্তমান ঠিকানা</label>
                    <textarea name="address" class="form-control" rows="3" placeholder="গ্রাম, ইউনিয়ন, উপজেলা, জেলা"></textarea>
                </div>
                <div class="objectives-box">
                    <div><strong><i class="fas fa-lightbulb me-2"></i>লক্ষ্য ও উদ্দেশ্যঃ</strong></div>
                    <div class="mt-2">আল্লাহ প্রদত্ত ও রাসূল (সাঃ) প্রদত্ত বিধান অনুযায়ী মানুষের সার্বিক জীবনের পুনর্বিন্যাস সাধন করে আল্লাহর সন্তষ্টি অর্জন</div>
                </div>
               
                <div class="form-check mt-4">
                    
                    <input class="form-check-input" type="checkbox" id="terms" required>
                    <label class="form-check-label  small" for="terms">
                        আমি স্বজ্ঞানে সাক্ষ্য দিচ্ছি যে, শিবিরের লক্ষ্য ও উদ্দেশ্যের সাথে আমি একমত।
                    </label>
                   </div>

                <button type="submit" class="btn-submit">আবেদন জমা দিন <i class="fas fa-paper-plane ms-2"></i></button>

                <div class="text-center mt-4">
                    <a href="/" class="text-secondary text-decoration-none small"><i class="fas fa-arrow-left me-1"></i> ফিরে যান হোম পেজে</a>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>