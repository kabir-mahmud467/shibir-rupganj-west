<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('partials/seo') %>

    <title>আর্কাইভ আপডেট | রূপগঞ্জ পশ্চিম</title>
    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* edit-archive.ejs specific styles only */
        .edit-archive-card { 
            background: rgba(30, 41, 59, 0.4); 
            backdrop-filter: blur(15px);
            padding: 30px; 
            border-radius: 20px; 
            max-width: 600px; 
            margin: 50px auto; 
            border: 1px solid rgba(255,255,255,0.1); 
            box-shadow: 0 15px 35px rgba(0,0,0,0.5);
        }

        h3 { 
            text-align: center; 
            color: #f97316; 
            margin-bottom: 25px; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            gap: 10px;
        }

        label { display: block; margin-top: 15px; color: #94a3b8; font-size: 14px; }

        input, textarea, select { 
            width: 100%; padding: 12px; margin: 8px 0; border-radius: 10px; 
            background: #0f172a; color: white; border: 1px solid #334155; 
            box-sizing: border-box; outline: none; transition: 0.3s;
        }

        input:focus, textarea:focus, select:focus { 
            border-color: #f97316; 
            box-shadow: 0 0 10px rgba(249, 115, 22, 0.2); 
        }

        .btn-update { 
            background: linear-gradient(45deg, #f97316, #ea580c); 
            color: white; border: none; padding: 14px; border-radius: 10px; 
            cursor: pointer; width: 100%; font-weight: bold; margin-top: 20px; 
            font-size: 16px; transition: 0.3s;
        }

        .btn-update:hover { transform: translateY(-2px); opacity: 0.9; }

        .back-link { 
            display: block; text-align: center; margin-top: 15px; 
            color: #94a3b8; text-decoration: none; font-size: 14px; 
            transition: 0.3s;
        }
        
        .back-link:hover { color: white; }

        @media (max-width: 600px) {
            .edit-archive-card { padding: 20px; margin: 20px 10px; }
        }
    </style>
</head>
<body>
    <%- include('partials/main-nav') %>
    
    <div class="edit-archive-card" style="margin-top: 40px; margin-bottom: 40px;">
        <h3><i class="fas fa-edit"></i> আর্কাইভ এডিট করুন</h3>
        
        <form action="/admin/update-archive/<%= item.id %>" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <label>শিরোনাম:</label>
            <input type="text" name="title" value="<%= item.title %>" placeholder="শিরোনাম লিখুন..." required>
            
            <label>প্রকার (যেমন: ছবি, ভিডিও, রিপোর্ট):</label>
            <input type="text" name="itemType" value="<%= item.itemType || '' %>" placeholder="প্রকার লিখুন...">
            
            <label>বিস্তারিত বর্ণনা:</label>
            <textarea name="description" rows="4" placeholder="বর্ণনা এখানে লিখুন..."><%= item.description %></textarea>
            
            <label>বর্তমান ইমেজ বা লিঙ্ক:</label>
            <div style="background: rgba(255,255,255,0.05); padding: 10px; border-radius: 10px; font-size: 12px; color: #94a3b8; margin-bottom: 10px; word-break: break-all;">
                <i class="fas fa-link me-1"></i> <%= item.url || 'কোনো লিঙ্ক নেই' %>
            </div>

            <label>নতুন ছবি আপলোড করুন (Direct Image):</label>
            <input type="file" name="image" accept="image/*">
            
            <div style="text-align: center; margin: 15px 0;">অথবা</div>

            <label>বাইরের লিঙ্ক (Drive Link / External URL):</label>
            <input type="url" name="url" value="<%= item.url && !item.url.includes('cloudinary') ? item.url : '' %>" placeholder="https://...">

            <button type="submit" class="btn-update">আপডেট নিশ্চিত করুন</button>
            <a href="/admin" class="back-link">
                <i class="fas fa-arrow-left"></i> পরিবর্তন ছাড়াই ফিরে যান
            </a>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
