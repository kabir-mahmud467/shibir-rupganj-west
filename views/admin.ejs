<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('partials/seo') %>

    <title>অ্যাডমিন কন্ট্রোল | রূপগঞ্জ পশ্চিম</title>
     <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        /* admin.ejs specific styles only */
        :root {
            --card-bg: rgba(30, 41, 59, 0.6);
            --border: rgba(255, 255, 255, 0.1);
            --primary-blue: #00d2ff;
        }

        .container { max-width: 1240px; margin: 0 auto; padding: 15px; }
        
        .admin-glass-card { 
            background: var(--card-bg); 
            backdrop-filter: blur(15px); 
            border-radius: 20px; 
            padding: 20px; 
            border: 1px solid var(--border); 
            margin-bottom: 25px; 
        }

        .grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); 
            gap: 20px; 
        }

        h3 { border-bottom: 1px solid var(--border); padding-bottom: 10px; margin-top: 0; display: flex; align-items: center; gap: 10px; font-size: 1.2rem; }
        
        input, select, textarea { 
            width: 100%; padding: 12px; margin: 8px 0; border-radius: 10px; 
            border: 1px solid #334155; background: #0f172a; color: white; 
            box-sizing: border-box; font-size: 14px; outline: none;
        }
        input:focus, textarea:focus { border-color: var(--primary-blue); }

        .btn { 
            width: 100%; padding: 12px; border-radius: 10px; border: none; 
            font-weight: bold; cursor: pointer; color: white; display: inline-block; 
            text-align: center; text-decoration: none; transition: 0.3s; 
        }
        
        .btn:hover { opacity: 0.8; transform: translateY(-2px); }
        .btn-blue { background: linear-gradient(45deg, #00d2ff, #3a7bd5); }
        .btn-orange { background: #f59e0b; }
        .btn-green { background: #10b981; }
        .btn-red { background: #ef4444; padding: 6px 12px; font-size: 12px; width: auto; color: white !important; cursor: pointer; }
        .btn-edit { background: #3b82f6; padding: 6px 12px; font-size: 12px; width: auto; color: white !important; text-decoration: none; }
        .btn-whatsapp { background: #25D366; padding: 6px 12px; font-size: 12px; width: auto; color: white !important; }

        .table-responsive { overflow-x: auto; -webkit-overflow-scrolling: touch; }
        .list-table { width: 100%; border-collapse: collapse; margin-top: 15px; min-width: 500px; }
        .list-table th { background: rgba(255,255,255,0.05); color: #94a3b8; font-weight: 500; font-size: 13px; text-align: left; }
        .list-table th, .list-table td { padding: 12px; border-bottom: 1px solid #1e293b; font-size: 14px; }

        .other-box { display: none; border-left: 3px solid var(--primary-blue); padding-left: 10px; margin-bottom: 10px; }
        .badge { padding: 4px 8px; border-radius: 6px; font-size: 10px; font-weight: bold; text-transform: uppercase; }
        .badge-pub { background: rgba(16, 185, 129, 0.2); color: #10b981; }
        .badge-priv { background: rgba(245, 158, 11, 0.2); color: #f59e0b; }
        .badge-app { background: rgba(59, 130, 246, 0.2); color: #3b82f6; }

        /* বায়তুলমাল মডাল */
        .bm-modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:9999; padding:20px; overflow-y:auto; }
        .bm-modal-overlay.active { display:flex; align-items:flex-start; justify-content:center; padding-top:60px; }
        .bm-modal { background:#0f172a; border:1px solid rgba(251,191,36,0.3); border-radius:18px; padding:28px; width:100%; max-width:520px; }
        .bm-month-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin:16px 0; }
        .bm-month-cell { display:flex; flex-direction:column; align-items:center; justify-content:center;
            border-radius:10px; padding:12px 6px; cursor:pointer; gap:5px;
            border:2px solid rgba(239,68,68,0.4); background:rgba(239,68,68,0.1); transition:0.2s; }
        .bm-month-cell.paid { border-color:#10b981; background:rgba(16,185,129,0.15); }
        .bm-month-cell .bm-icon { font-size:18px; font-weight:bold; color:#ef4444; }
        .bm-month-cell.paid .bm-icon { color:#10b981; }
        .bm-month-cell .bm-name { font-size:11px; font-weight:600; color:#ef4444; }
        .bm-month-cell.paid .bm-name { color:#10b981; }

        @media (max-width: 600px) {
            .container { padding: 10px; }
            .admin-glass-card { padding: 15px; border-radius: 15px; }
            h3 { font-size: 1rem; }
            .btn { padding: 10px; font-size: 14px; }
        }
    </style>
</head>
<body>

    <%- include('partials/main-nav') %>

    <div class="container">
        <div class="grid">
            <div class="admin-glass-card">
                <h3 style="color:var(--primary-blue);"><i class="fas fa-user-plus"></i> জনশক্তি যোগ</h3>
                <form action="/admin/add-member" method="POST" enctype="multipart/form-data">
                    <input type="text" name="name" placeholder="নাম" required>
                    <div style="display: flex; gap: 10px;">
                        <input type="text" name="father" placeholder="পিতার নাম">
                        <input type="text" name="mother" placeholder="মাতার নাম">
                    </div>
                    
                    <div style="display: flex; gap: 10px;">
                        <input type="date" name="dob" title="জন্ম তারিখ">
                        <input type="text" name="phone" placeholder="ফোন নম্বর" required>
                    </div>

                    <input type="url" name="facebook" placeholder="ফেসবুক আইডি লিঙ্ক (https://...)">

                    <textarea name="present_address" placeholder="বর্তমান ঠিকানা" rows="2"></textarea>
                    <textarea name="permanent_address" placeholder="স্থায়ী ঠিকানা" rows="2"></textarea>
                    <input type="text" name="ward" placeholder="ওয়ার্ডের নাম">
                    <input type="text" name="branch" placeholder="উপশাখার নাম">
                    <input type="text" name="guardian_phone" placeholder="অভিভাবকের ফোন নম্বর">
                    
                    <select name="type" required>
                        <option value="">সাংগঠনিক মান</option>
                        <option value="কর্মী">কর্মী</option>
                        <option value="সাথী">সাথী</option>
                    </select>

                    <select name="edu" onchange="toggleBox(this, 'eduO')">
                        <option value="">শিক্ষা স্তর</option>
                        <% ['৫ম শ্রেণি','৬ষ্ঠ শ্রেণি','৭ম শ্রেণি','৮ম শ্রেণি','৯ম শ্রেণি','১০ম শ্রেণি','একাদশ শ্রেণি','দ্বাদশ শ্রেণি','অনার্স ১ম বর্ষ','অনার্স ২য় বর্ষ','অনার্স ৩য় বর্ষ','অনার্স ৪র্থ বর্ষ','মাস্টার্স','অন্যান্য'].forEach(opt => { %>
                            <option value="<%= opt %>"><%= opt %></option>
                        <% }) %>
                    </select>
                    <div id="eduO" class="other-box"><input type="text" name="edu_other" placeholder="শিক্ষার বিস্তারিত..."></div>

                    <select name="inst" onchange="toggleBox(this, 'instO')">
                        <option value="">শিক্ষা প্রতিষ্ঠান</option>
                        <% ['প্রাথমিক বিদ্যালয়','মাধ্যমিক বিদ্যালয়','কওমী মাদ্রাসা','ইবতেদায়ী মাদ্রাসা','দাখিল মাদ্রাসা','ফাজিল মাদ্রাসা','আলিম মাদ্রাসা','কামিল মাদ্রাসা','কলেজ','বিশ্ববিদ্যালয় (সরকারী)','বিশ্ববিদ্যালয় (বেসরকারী)','মেডিকেল কলেজ','ডেন্টাল কলেজ','নার্সিং কলেজ','কৃষি বিশ্ববিদ্যালয়','পলিটেকনিক ইন্সটিটিউট','ইঞ্জিনিয়ারিং কলেজ','ইঞ্জিনিয়ারিং বিশ্ববিদ্যালয়','অন্যান্য'].forEach(opt => { %>
                            <option value="<%= opt %>"><%= opt %></option>
                        <% }) %>
                    </select>
                    <div id="instO" class="other-box"><input type="text" name="inst_other" placeholder="প্রতিষ্ঠানের নাম..."></div>

                    <select name="responsibility">
                        <option value="">দায়িত্ব</option>
                        <% ['থানা সভাপতি','থানা সেক্রেটারি','থানা সাংগঠনিক সম্পাদক','থানা বায়তুলমাল সম্পাদক','থানা সেক্রেটারিয়েট','ওয়ার্ড সভাপতি','ওয়ার্ড সেক্রেটারি','ওয়ার্ড সাংগঠনিক সম্পাদক','ওয়ার্ড বায়তুলমাল সম্পাদক','ওয়ার্ড সেক্রেটারিয়েট','উপশাখা সভাপতি','উপশাখা সেক্রেটারি','উপশাখা সাংগঠনিক সম্পাদক','উপশাখা বায়তুলমাল সম্পাদক','উপশাখা সেক্রেটারিয়েট'].forEach(opt => { %>
                            <option value="<%= opt %>"><%= opt %></option>
                        <% }) %>
                    </select>

                    <textarea name="comment" placeholder="মন্তব্য..."></textarea>

                    <div style="display: flex; align-items: center; gap: 10px; margin: 5px 0; background: rgba(251,191,36,0.08); border: 1px solid rgba(251,191,36,0.3); border-radius: 10px; padding: 10px 14px;">
                        <i class="fas fa-coins" style="color: #fbbf24; font-size: 18px;"></i>
                        <div style="flex: 1;">
                            <label style="font-size: 12px; color: #fbbf24; margin: 0; font-weight: 600;">বায়তুলমাল ধার্য (মাসিক, টাকায়)</label>
                            <input type="number" name="baitul_mal_amount" placeholder="০" min="0" step="0.5" style="margin: 4px 0 0; background: rgba(0,0,0,0.3); border-color: rgba(251,191,36,0.4); color: #fbbf24;">
                        </div>
                    </div>

                    <div style="margin-top: 15px; background: rgba(251,191,36,0.06); border: 1px solid rgba(251,191,36,0.25); border-radius: 12px; padding: 15px;">
                        <h4 style="color: #fbbf24; margin-bottom: 8px; font-size: 0.9rem; display: flex; align-items: center; gap: 8px;">
                            <i class="fas fa-calendar-check"></i> বায়তুলমাল পরিশোধ (১২ মাস)
                        </h4>
                        <div class="bm-month-grid" style="grid-template-columns: repeat(4, 1fr); gap: 6px; margin: 10px 0;">
                            <% const addMemberMonths = ['জানুয়ারি','ফেব্রুয়ারি','মার্চ','এপ্রিল','মে','জুন','জুলাই','আগস্ট','সেপ্টেম্বর','অক্টোবর','নভেম্বর','ডিসেম্বর']; %>
                            <% for(let i = 0; i < 12; i++) { %>
                                <div class="bm-month-cell" onclick="const cb=this.querySelector('input'); cb.checked=!cb.checked; this.classList.toggle('paid', cb.checked); this.querySelector('.bm-icon').textContent=cb.checked?'✓':'✕';">
                                    <span class="bm-icon">✕</span>
                                    <span class="bm-name"><%= addMemberMonths[i] %></span>
                                    <input type="checkbox" name="month_<%= i %>" style="display:none;">
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <label style="font-size: 12px; color: #94a3b8; margin-left: 5px; margin-top: 10px; display: block;">সদস্যের ছবি:</label>
                    <input type="file" name="photo">
                    <input type="password" name="password" placeholder="গোপন কোড (পাসওয়ার্ড)" required>
                    <button type="submit" class="btn btn-blue">তথ্য সেভ করুন</button>
                </form>
            </div>

            <div class="admin-glass-card">
                <h3 style="color:#10b981;"><i class="fas fa-heart"></i> শুভাকাঙ্ক্ষী যোগ</h3>
                <form action="/admin/add-supporter" method="POST">
                    <input type="text" name="name" placeholder="নাম" required>
                    <input type="text" name="address" placeholder="ঠিকানা">
                    <input type="text" name="phone" placeholder="ফোন নম্বর" required>
                    <div style="display: flex; gap: 10px;">
                        <input type="text" name="profession" placeholder="পেশা">
                        <input type="text" name="password" placeholder="গোপন কোড (লগইনের জন্য)" required>
                    </div>
                    <input type="url" name="facebook" placeholder="ফেসবুক আইডি লিঙ্ক">
                    
                    <label style="font-size: 12px; color: #94a3b8; margin-left: 5px;">প্রোফাইল ছবি:</label>
                    <input type="file" name="photo" accept="image/*">
                    
                    <div style="display: flex; align-items: center; gap: 10px; margin: 10px 0; background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.3); border-radius: 10px; padding: 10px 14px;">
                        <i class="fas fa-hand-holding-dollar" style="color: #10b981; font-size: 18px;"></i>
                        <div style="flex: 1;">
                            <label style="font-size: 12px; color: #10b981; margin: 0; font-weight: 600;"> মাসিক বায়তুলমাল ধার্য</label>
                            <input type="number" name="target_amount" placeholder="০" min="0" style="margin: 4px 0 0; background: rgba(0,0,0,0.3); border-color: rgba(16,185,129,0.4); color: #10b981;">
                        </div>
                    </div>

                    <div style="margin-top: 15px; background: rgba(16,185,129,0.06); border: 1px solid rgba(16,185,129,0.25); border-radius: 12px; padding: 15px;">
                        <h4 style="color: #10b981; margin-bottom: 8px; font-size: 0.9rem; display: flex; align-items: center; gap: 8px;">
                            <i class="fas fa-calendar-check"></i> পরিশোধের চার্ট (১২ মাস)
                        </h4>
                        <div class="bm-month-grid" style="grid-template-columns: repeat(4, 1fr); gap: 6px; margin: 10px 0;">
                            <% const addSupMonths = ['জানুয়ারি','ফেব্রুয়ারি','মার্চ','এপ্রিল','মে','জুন','জুলাই','আগস্ট','সেপ্টেম্বর','অক্টোবর','নভেম্বর','ডিসেম্বর']; %>
                            <% for(let i = 0; i < 12; i++) { %>
                                <div class="bm-month-cell" style="border-color: rgba(16,185,129,0.2);" onclick="const cb=this.querySelector('input'); cb.checked=!cb.checked; this.classList.toggle('paid', cb.checked); this.querySelector('.bm-icon').textContent=cb.checked?'✓':'✕';">
                                    <span class="bm-icon">✕</span>
                                    <span class="bm-name"><%= addSupMonths[i] %></span>
                                    <input type="checkbox" name="sup_month_<%= i %>" style="display:none;">
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-green mt-3">শুভাকাঙ্ক্ষী সংরক্ষণ করুন</button>
                </form>
            </div>

            <div class="forms-column">
                <div class="admin-glass-card">
                    <h3 style="color:#f59e0b;"><i class="fas fa-bullhorn"></i> নতুন নোটিশ</h3>
                    <form action="/admin/add-notice" method="POST">
                        <input type="text" name="title" placeholder="নোটিশের শিরোনাম" required>
                        <textarea name="content" placeholder="নোটিশের বিস্তারিত লিখুন..." rows="4"></textarea>
                        <select name="visibility">
                            <option value="পাবলিক">পাবলিক (সবাই দেখবে)</option>
                            <option value="কর্মী">কর্মী (শুধু কর্মীরা)</option>
                            <option value="সাথী">সাথী (শুধু সাথীরা)</option>
                        </select>
                        <button type="submit" class="btn btn-orange">পাবলিশ নোটিশ</button>
                    </form>
                </div>
                
                <div class="admin-glass-card">
                    <h3 style="color:#10b981;"><i class="fas fa-file-arrow-up"></i> লাইব্রেরি ফাইল</h3>
                    <form action="/admin/add-resource" method="POST">
                        <input type="text" name="title" placeholder="ফাইলের নাম বা শিরোনাম" required>
                        <select name="visibility">
                            <option value="পাবলিক">পাবলিক</option>
                            <option value="কর্মী">কর্মী</option>
                            <option value="সাথী">সাথী</option>
                        </select>
                        <input type="url" name="url" placeholder="বইয়ের লিঙ্ক (Google Drive/URL)">
                        <input type="url" name="imageUrl" placeholder="বইয়ের ছবির URL (Cloudinary/ইত্যাদি)">
                        <button type="submit" class="btn btn-green">লাইব্রেরি সংযোজন করুন</button>
                    </form>
                </div>

                <div class="admin-glass-card">
                    <h3 style="color:#7c3aed;"><i class="fas fa-images"></i> হোম পেজ স্লাইড</h3>
                    <form action="/admin/add-slide" method="POST" enctype="multipart/form-data" onsubmit="const btn = document.getElementById('slideBtn'); btn.innerHTML = '<i class=\'fas fa-spinner fa-spin\'></i> আপলোড হচ্ছে... অপেক্ষা করুন'; btn.disabled = true; btn.style.opacity = '0.7';">
                        <input type="text" name="title" placeholder="স্লাইড শিরোনাম" required>
                        <input type="text" name="caption" placeholder="ছোট বর্ণনা (Caption)">
                        <label style="font-size: 12px; color: #94a3b8; margin-left: 5px;">স্লাইডের ছবি (Upload Image):</label>
                        <input type="file" name="image" accept="image/*" required>
                        <button type="submit" id="slideBtn" class="btn btn-blue">স্লাইড যোগ করুন</button>
                    </form>
                </div>

                <div class="admin-glass-card">
                    <h3 style="color:#f97316;"><i class="fas fa-archive"></i> আর্কাইভ আইটেম</h3>
                    <form action="/admin/add-archive" method="POST" enctype="multipart/form-data">
                        <input type="text" name="title" placeholder="শিরোনাম" required>
                        <input type="text" name="itemType" placeholder="প্রকার (ভিডিও, ছবি, ডকুমেন্ট)">
                        <textarea name="description" rows="3" placeholder="বর্ণনা অথবা বিস্তারিত লিখুন"></textarea>
                        
                        <label style="font-size: 13px; color: #94a3b8; margin-top: 10px; display: block;">ছবি আপলোড করুন (Direct Image):</label>
                        <input type="file" name="image" accept="image/*" style="padding: 10px;">
                        
                        <div style="text-align: center; color: #475569; font-size: 12px; margin: 10px 0;">— অথবা —</div>
                        
                        <input type="url" name="url" placeholder="Google Drive / অন্য লিঙ্ক">
                        <button type="submit" class="btn btn-orange">আর্কাইভ যুক্ত করুন</button>
                    </form>
                </div>


                <div class="admin-glass-card">
                    <h3 style="color:#22c55e;"><i class="fas fa-book-open"></i> ইতিহাস / দায়িত্বশীল</h3>
                    <form action="/admin/add-history" method="POST">
                        <select name="category" required>
                            <option value="history">থানার ইতিহাস</option>
                            <option value="officials">প্রাক্তন দায়িত্বশীল</option>
                            <option value="martyrs">শহিদদের তালিকা</option>
                        </select>
                        <input type="text" name="title" placeholder="শিরোনাম বা নাম" required>
                        <textarea name="body" rows="3" placeholder="বিবরণ / দায়িত্ব / ইতিহাস"></textarea>
                        <input type="text" name="extra" placeholder="অতিরিক্ত তথ্য (যদি থাকে)">
                        <button type="submit" class="btn btn-green">এন্ট্রি সংরক্ষণ করুন</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="admin-glass-card">
            <h3 style="color:#3b82f6;"><i class="fas fa-hand-holding-heart"></i> নতুন সমর্থক আবেদনসমূহ</h3>
            <div class="table-responsive">
                <table class="list-table">
                    <thead>
                        <tr>
                            <th>নাম</th>
                            <th>মোবাইল</th>
                            <th>প্রতিষ্ঠান</th>
                            <th>অ্যাকশন</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(data.applications && data.applications.length > 0) { %>
                            <% data.applications.forEach(app => { %>
                                <tr>
                                    <td><strong><%= app.name %></strong><br><small style="color:#64748b;"><%= app.date %></small></td>
                                    <td><%= app.phone %></td>
                                    <td><span class="badge badge-app"><%= app.institution %></span></td>
                                    <td>
                                        <div style="display: flex; gap: 5px;">
                                            <a href="https://wa.me/88<%= app.phone %>" target="_blank" class="btn btn-whatsapp"><i class="fab fa-whatsapp"></i></a>
                                            <button onclick="confirmDel('/admin/delete-app/<%= app._id %>')" class="btn btn-red"><i class="fas fa-trash"></i></button>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="4" style="text-align:center; color:#64748b;">কোনো নতুন আবেদন নেই</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="admin-glass-card">
            <h3 style="color:#3b82f6; border:none;"><i class="fas fa-users"></i> জনশক্তি তালিকা</h3>
            <div class="table-responsive">
                <table class="list-table">
                    <thead><tr><th>নাম ও ফোন</th><th>মান</th><th>বায়তুলমাল</th><th>দায়িত্ব</th><th>অ্যাকশন</th></tr></thead>
                    <tbody>
                        <% data.members.forEach(m => { %>
                            <%
                                const bmpaid = (m.baitul_mal_payment || []).filter(p => p).length;
                                const bmtotal = 12;
                            %>
                            <tr>
                                <td>
                                    <strong><%= m.name %></strong><br>
                                    <small style="color:var(--primary-blue)"><%= m.phone %></small>
                                </td>
                                <td><span class="badge badge-pub"><%= m.type %></span></td>
                                <td>
                                    <% if (m.baitul_mal_amount) { %>
                                    <button onclick="const btn=this; openBmModal(btn.dataset.id, btn.dataset.name, btn.dataset.amount, JSON.parse(btn.dataset.payments))"
                                        data-id="<%= m._id %>"
                                        data-name="<%= m.name %>"
                                        data-amount="<%= m.baitul_mal_amount || 0 %>"
                                        data-payments='<%- JSON.stringify(m.baitul_mal_payment || Array(12).fill(false)) %>'
                                        style="background: rgba(251,191,36,0.15); border:1px solid rgba(251,191,36,0.4); color:#fbbf24; border-radius:8px; padding:5px 10px; font-size:12px; cursor:pointer; font-weight:600;">
                                        <i class="fas fa-coins"></i> <%= m.baitul_mal_amount %>৳ &nbsp;<span style="font-size:10px;">(<%= bmpaid %>/<%= bmtotal %>)</span>
                                    </button>
                                    <% } else { %>
                                    <span style="color:#475569; font-size:12px;">—</span>
                                    <% } %>
                                </td>
                                <td><%= m.responsibility %></td>
                                <td>
                                    <div style="display: flex; gap: 5px;">
                                        <a href="/admin/edit-member/<%= m._id %>" class="btn btn-edit">এডিট</a>
                                        <button onclick="confirmDel('/admin/delete-member/<%= m._id %>')" class="btn btn-red">মুছুন</button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="admin-glass-card">
            <h3 style="color:#10b981; border:none;"><i class="fas fa-users-rectangle"></i> শুভাকাঙ্ক্ষী তালিকা</h3>
            <div class="table-responsive">
                <table class="list-table">
                    <thead><tr><th>নাম ও ফোন</th><th>পেশা</th><th>আদায়</th><th>অ্যাকশন</th></tr></thead>
                    <tbody>
                        <% if(data.supporters && data.supporters.length > 0) { %>
                            <% data.supporters.forEach(s => { %>
                                <%
                                    const spaid = (s.payments || []).filter(p => p).length;
                                %>
                                <tr>
                                    <td>
                                        <div style="display: flex; align-items: center; gap: 10px;">
                                            <% if(s.photo) { %>
                                                <img src="<%= s.photo %>" width="35" height="35" style="border-radius: 50%; object-fit: cover; border: 1px solid #10b981;" alt="p">
                                            <% } else { %>
                                                <div style="width:35px; height:35px; border-radius:50%; background:rgba(16,185,129,0.1); display:flex; align-items:center; justify-content:center; color:#10b981; border: 1px solid #10b98133;">
                                                    <i class="fas fa-user" style="font-size:12px;"></i>
                                                </div>
                                            <% } %>
                                            <div>
                                                <strong><%= s.name %></strong><br>
                                                <small style="color:#10b981"><%= s.phone %></small>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="badge badge-pub"><%= s.profession || 'সাধারণ' %></span></td>
                                    <td>
                                        <button onclick="const btn=this; openSpModal(btn.dataset.id, btn.dataset.name, btn.dataset.amount, JSON.parse(btn.dataset.payments))"
                                            data-id="<%= s._id %>"
                                            data-name="<%= s.name %>"
                                            data-amount="<%= s.target_amount || 0 %>"
                                            data-payments='<%- JSON.stringify(s.payments || Array(12).fill(false)) %>'
                                            style="background: rgba(16,185,129,0.15); border:1px solid rgba(16,185,129,0.4); color:#10b981; border-radius:8px; padding:5px 10px; font-size:12px; cursor:pointer; font-weight:600;">
                                            <i class="fas fa-hand-holding-dollar"></i> <%= s.target_amount %>৳ &nbsp;<span style="font-size:10px;">(<%= spaid %>/12)</span>
                                        </button>
                                    </td>
                                    <td>
                                        <div style="display: flex; gap: 5px;">
                                            <a href="/admin/edit-supporter/<%= s._id %>" class="btn btn-edit" style="background: #10b981;">এডিট</a>
                                            <button onclick="confirmDel('/admin/delete-supporter/<%= s._id %>')" class="btn btn-red">মুছুন</button>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="4" style="text-align:center; color:#64748b;">কোনো শুভাকাঙ্ক্ষী নেই</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="grid">
            <div class="admin-glass-card">
                <h3><i class="fas fa-list-check"></i> নোটিশ লিস্ট</h3>
                <div class="table-responsive">
                    <table class="list-table">
                        <thead><tr><th>শিরোনাম</th><th>দৃশ্যমানতা</th><th>অ্যাকশন</th></tr></thead>
                        <tbody>
                            <% data.notices.forEach(n => { %>
                                <tr>
                                    <td><%= n.title %></td>
                                    <td><span class="badge badge-priv"><%= n.visibility %></span></td>
                                    <td>
                                        <div style="display: flex; gap: 12px; align-items: center;">
                                            <a href="/admin/edit-notice/<%= n._id %>" style="color:#3b82f6;"><i class="fas fa-edit"></i></a>
                                            <i onclick="confirmDel('/admin/delete-notice/<%= n._id %>')" class="fas fa-trash" style="color:#ef4444; cursor:pointer;"></i>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="admin-glass-card">
                <h3><i class="fas fa-folder-open"></i> ফাইল লিস্ট</h3>
                <div class="table-responsive">
                    <table class="list-table">
                        <thead><tr><th>ফাইলের নাম</th><th>টাইপ</th><th>অ্যাকশন</th></tr></thead>
                        <tbody>
                            <% data.resources.forEach(r => { %>
                                <tr>
                                    <td><%= r.title %></td>
                                    <td><span class="badge badge-pub"><%= r.visibility %></span></td>
                                    <td>
                                        <div style="display: flex; gap: 12px; align-items: center;">
                                            <a href="/admin/edit-resource/<%= r._id %>" style="color:#3b82f6;"><i class="fas fa-edit"></i></a>
                                            <i onclick="confirmDel('/admin/delete-resource/<%= r._id %>')" class="fas fa-trash" style="color:#ef4444; cursor:pointer;"></i>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="grid">
            <div class="admin-glass-card">
                <h3><i class="fas fa-images"></i> স্লাইড ম্যানেজার</h3>
                <div class="table-responsive">
                    <table class="list-table">
                        <thead><tr><th>ছবি</th><th>শিরোনাম</th><th></th></tr></thead>
                        <tbody>
                            <% data.slides.forEach(s => { %>
                                <tr>
                                    <td>
                                        <% if(s.imageUrl) { %>
                                            <img src="<%= s.imageUrl %>" width="60" style="border-radius: 5px;" alt="Slide Image">
                                        <% } else { %>
                                            <span style="color:#64748b;">No Image</span>
                                        <% } %>
                                    </td>
                                    <td><%= s.title %></td>
                                    <td>
                                        <i onclick="editSlide(this)" data-id="<%= s._id %>" data-title="<%= s.title %>" data-caption="<%= s.caption %>" class="fas fa-edit" style="color:#3b82f6; cursor:pointer; margin-right:15px;" title="স্লাইড সম্পাদনা করুন"></i>
                                        <i onclick="confirmDel('/admin/delete-slide/<%= s._id %>')" class="fas fa-trash" style="color:#ef4444; cursor:pointer;" title="স্লাইড ডিলিট করুন"></i>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="admin-glass-card">
                <h3><i class="fas fa-archive"></i> আর্কাইভ ম্যানেজার</h3>
                <div class="table-responsive">
                    <table class="list-table">
                        <thead><tr><th>শিরোনাম</th><th>প্রকার</th><th></th></tr></thead>
                        <tbody>
                            <% data.archives.forEach(item => { %>
                                <tr>
                                    <td><%= item.title %></td>
                                    <td><%= item.itemType || 'অন্যান্য' %></td>
                                    <td>
                                        <div style="display: flex; gap: 12px; align-items: center;">
                                            <a href="/admin/edit-archive/<%= item._id %>" style="color:#3b82f6;"><i class="fas fa-edit"></i></a>
                                            <i onclick="confirmDel('/admin/delete-archive/<%= item._id %>')" class="fas fa-trash" style="color:#ef4444; cursor:pointer;"></i>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>


        <div class="admin-glass-card">
            <h3><i class="fas fa-book-open"></i> ইতিহাস ও শহিদ তালিকা</h3>
            <div class="table-responsive">
                <table class="list-table">
                    <thead><tr><th>ক্যাটেগরি</th><th>শিরোনাম</th><th></th></tr></thead>
                    <tbody>
                        <% data.historyItems.forEach(item => { %>
                            <tr>
                                <td><%= item.category %></td>
                                <td><%= item.title %></td>
                                <td><i onclick="confirmDel('/admin/delete-history/<%= item._id %>')" class="fas fa-trash" style="color:#ef4444; cursor:pointer;"></i></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- বায়তুলমাল পরিশোধ মডাল -->
    <div class="bm-modal-overlay" id="bmOverlay" onclick="closeBmModal(event)">
        <div class="bm-modal">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;">
                <h4 style="color:#fbbf24; margin:0; font-size:1rem; display:flex; align-items:center; gap:8px;">
                    <i class="fas fa-coins"></i> বায়তুলমাল পরিশোধ
                </h4>
                <button onclick="document.getElementById('bmOverlay').classList.remove('active')" style="background:none; border:none; color:#94a3b8; font-size:20px; cursor:pointer;">&times;</button>
            </div>
            <div id="bmMemberInfo" style="font-size:13px; color:#94a3b8; margin-bottom:4px;"></div>
            <p id="bmAmountInfo" style="font-size:14px; color:#fbbf24; font-weight:700; margin-bottom:4px;"></p>

            <form id="bmForm" method="POST">
                <div class="bm-month-grid" id="bmGrid"></div>
                <button type="submit" style="
                    width:100%; padding:12px; border-radius:10px; margin-top:8px;
                    background:linear-gradient(45deg,#fbbf24,#f59e0b); color:#0f172a;
                    font-weight:bold; border:none; cursor:pointer; font-size:14px;
                ">
                    <i class="fas fa-check-circle me-1"></i> পরিশোধ সেভ করুন
                </button>
            </form>
        </div>
    </div>

    <!-- Edit Slide Modal -->
    <div class="modal fade" id="editSlideModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content" style="background:#0f172a; color:#fff; border: 1px solid rgba(255,255,255,0.1);">
                <div class="modal-header" style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                    <h5 class="modal-title">স্লাইড আপডেট করুন</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="editSlideForm" method="POST" enctype="multipart/form-data" onsubmit="const btn = this.querySelector('button[type=submit]'); btn.innerHTML = '<i class=\'fas fa-spinner fa-spin\'></i> আপলোড হচ্ছে...'; btn.disabled = true;">
                        <label style="font-size: 13px; color: #94a3b8;">স্লাইড শিরোনাম:</label>
                        <input type="text" name="title" id="editSlideTitle" class="form-control mb-3" style="background: rgba(255,255,255,0.05); color: #fff; border: none; padding: 10px;" required>
                        
                        <label style="font-size: 13px; color: #94a3b8;">ছোট বর্ণনা (Caption):</label>
                        <input type="text" name="caption" id="editSlideCaption" class="form-control mb-3" style="background: rgba(255,255,255,0.05); color: #fff; border: none; padding: 10px;">
                        
                        <label style="font-size: 13px; color: #f59e0b;">নতুন ছবি (শুধু যদি পরিবর্তন করতে চান):</label>
                        <input type="file" name="image" accept="image/*" class="form-control mb-4" style="background: rgba(255,255,255,0.05); color: #fff; border: none; padding: 10px;">
                        
                        <button type="submit" class="btn btn-blue w-100 py-2">আপডেট সেভ করুন</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        const BM_MONTHS = ['জানুয়ারি','ফেব্রুয়ারি','মার্চ','এপ্রিল','মে','জুন','জুলাই','আগস্ট','সেপ্টেম্বর','অক্টোবর','নভেম্বর','ডিসেম্বর'];
        let bmPayState = Array(12).fill(false);

        function openBmModal(id, name, amount, payments) {
            bmPayState = payments.slice();
            document.getElementById('bmMemberInfo').textContent = '👤 ' + name;
            document.getElementById('bmAmountInfo').textContent = 'মাসিক ধার্য: ' + amount + ' টাকা';
            document.getElementById('bmForm').action = '/admin/update-baitul-mal/' + id;
            renderBmGrid();
            document.getElementById('bmOverlay').classList.add('active');
        }

        function renderBmGrid() {
            const grid = document.getElementById('bmGrid');
            grid.innerHTML = '';
            bmPayState.forEach((paid, i) => {
                const cell = document.createElement('div');
                cell.className = 'bm-month-cell' + (paid ? ' paid' : '');
                cell.innerHTML = `
                    <span class="bm-icon">${paid ? '✓' : '✕'}</span>
                    <span class="bm-name">${BM_MONTHS[i]}</span>
                    <input type="checkbox" name="month_${i}" ${paid ? 'checked' : ''} style="display:none;">
                `;
                cell.addEventListener('click', () => toggleBmCell(i, cell));
                grid.appendChild(cell);
            });
        }

        function toggleBmCell(i, cell) {
            bmPayState[i] = !bmPayState[i];
            const paid = bmPayState[i];
            cell.classList.toggle('paid', paid);
            cell.querySelector('.bm-icon').textContent = paid ? '✓' : '✕';
            const cb = cell.querySelector('input[type=checkbox]');
            cb.checked = paid;
        }

        function closeBmModal(e) {
            if (e.target === document.getElementById('bmOverlay')) {
                document.getElementById('bmOverlay').classList.remove('active');
            }
        }

        function editSlide(btn) {
            document.getElementById('editSlideForm').action = '/admin/update-slide/' + btn.getAttribute('data-id');
            document.getElementById('editSlideTitle').value = btn.getAttribute('data-title') || '';
            document.getElementById('editSlideCaption').value = btn.getAttribute('data-caption') || '';
            new bootstrap.Modal(document.getElementById('editSlideModal')).show();
        }

        function openSpModal(id, name, amount, payments) {
            bmPayState = payments.slice();
            document.getElementById('bmMemberInfo').textContent = '👤 ' + name + ' (শুভাকাঙ্ক্ষী)';
            document.getElementById('bmAmountInfo').textContent = 'মাসিক ধার্য: ' + amount + ' টাকা';
            document.getElementById('bmForm').action = '/admin/update-supporter-payment/' + id;
            renderBmGrid();
            document.getElementById('bmOverlay').classList.add('active');
        }

        function toggleBox(select, id) {
            document.getElementById(id).style.display = (select.value === 'অন্যান্য') ? 'block' : 'none';
        }

        function confirmDel(url) {
            Swal.fire({
                title: 'আপনি কি নিশ্চিত?',
                text: "এটি ডিলিট করলে আর ফিরে পাওয়া যাবে না!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'হ্যাঁ, ডিলিট করুন!',
                cancelButtonText: 'বাতিল',
                background: '#0f172a',
                color: '#fff'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = url;
                }
            })
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>`